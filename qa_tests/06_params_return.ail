fn add(a, b) {
    return a + b
}

fn identity(x) {
    return x
}

fn multi_return(a, b) {
    if (a > b) { return a }
    return b
}

fn no_return(x) {
    let y = x + 1
}

fn main() {
    print("add:", add(3, 4));
    print("id:", identity(42));
    print("max:", multi_return(10, 20));
    print("no_return:", no_return(5));
    return 0
}
