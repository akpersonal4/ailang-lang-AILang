}

fn handle_filter_assignee(boards_hfa) {
    if (list.len(boards_hfa) == 0) {
        print("No boards.");
        return boards_hfa;
    }
    let board_hfa_ref = list.get(boards_hfa, 0);
    print("Tasks assigned to Alice:");
