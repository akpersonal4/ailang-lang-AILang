fn handle_statistics(boards_hst) {
    if (list.len(boards_hst) == 0) {
        print("No boards.");
        return boards_hst;
    }
    count_by_column_stats(list.get(boards_hst, 0));
    count_by_priority_all(list.get(boards_hst, 0));
    return boards_hst;
}

fn handle_report(boards_hrp) {
    if (list.len(boards_hrp) == 0) {
        print("No boards.");
        return boards_hrp;
    }
    generate_report(list.get(boards_hrp, 0));
    return boards_hrp;
}

fn handle_export(boards_hex) {
    export_all_boards(boards_hex);
    return boards_hex;
}

fn handle_import(boards_hi) {
    let imported_hi = import_all_boards();
    if (list.len(imported_hi) > 0) {
        save_boards(merge_lists(boards_hi, imported_hi, 0));
        print("Import complete.");
    }
    return boards_hi;
}

fn handle_demo(boards_hd) {
    boards_hd = create_demo_board(boards_hd);
    if (list.len(boards_hd) > 0) {
        let board_hd_ref = list.get(boards_hd, 0);
        if (map.has(board_hd_ref, "id")) {
            board_global_id = map.get(board_hd_ref, "id");
        }
    }
    print("Demo data loaded.");
    return boards_hd;
}

fn handle_update_field(boards_huf) {
    if (list.len(boards_huf) == 0) {
        print("No boards.");
        return boards_huf;
    }
    let board_huf_ref = list.get(boards_huf, 0);
    if (map.has(board_huf_ref, "id")) {
        boards_huf = update_task_field_simple(boards_huf, map.get(board_huf_ref, "id"), 1, "priority", "Critical");
        print("Updated task ID 1 priority to Critical.");
    }
    return boards_huf;
}

fn demo_flow(boards_df) {
    boards_df = handle_demo(boards_df);
    print("");
    if (list.len(boards_df) > 0) {
        let board_df = list.get(boards_df, 0);
        board_display(board_df);
        print("");
        print_all_tasks(board_df);
        print("");
        generate_report(board_df);
    }
    print("");
    print("=== End of Kanban Demo ===");
    return boards_df;
}

// ============================================================
// Level N: main()
// ============================================================
fn main() {
    let boards_main = list.new();
    boards_main = demo_flow(boards_main);
    save_boards(boards_main);
    print("Data saved to kanban_data.json");
    return 0;
}
