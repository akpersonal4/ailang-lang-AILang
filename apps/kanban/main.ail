fn handle_list_boards(boards_hlb) {
    print_all_boards(boards_hlb);
    return boards_hlb;
}

fn handle_create_board_ui(boards_hcb) {
    let board_hcb = make_board("New Board", "Default description");
    let result_hcb = add_board_to_list(boards_hcb, board_hcb);
    let bid_hcb = -1;
    if (map.has(board_hcb, "id")) {
        bid_hcb = map.get(board_hcb, "id");
    }
    print("Created board ID:", convert.to_string(bid_hcb));
    return result_hcb;
}

fn handle_delete_board_ui(boards_hdb) {
    print("Enter board ID to delete:");
    print("(Using first board for demo)");
    if (list.len(boards_hdb) > 0) {
        let board_hdb = list.get(boards_hdb, 0);
        if (map.has(board_hdb, "id")) {
            boards_hdb = delete_board_wrapper(boards_hdb, map.get(board_hdb, "id"));
            print("Deleted board.");
        }
    }
    return boards_hdb;
}

fn handle_show_board(boards_hsb) {
    print("Enter board ID:");
    print("(Using first board for demo)");
    if (list.len(boards_hsb) > 0) {
        let board_hsb = list.get(boards_hsb, 0);
        board_display(board_hsb);
        print("");
        print_all_tasks(board_hsb);
    }
    return boards_hsb;
}

fn handle_add_task_ui(boards_hat) {
    if (list.len(boards_hat) == 0) {
        print("No boards exist.");
        return boards_hat;
    }
    let board_hat_ref = list.get(boards_hat, 0);
    if (map.has(board_hat_ref, "id")) {
        boards_hat = add_task_to_board(boards_hat, map.get(board_hat_ref, "id"), "Todo", "New Task", "Description", "Medium", "", "Unassigned");
        print("Added task to Todo column.");
    }
    return boards_hat;
}

fn handle_move_task_ui(boards_hmt) {
    if (list.len(boards_hmt) == 0) {
        print("No boards.");
        return boards_hmt;
    }
    let board_hmt_ref = list.get(boards_hmt, 0);
    if (map.has(board_hmt_ref, "columns")) {
        let cols_hmt = map.get(board_hmt_ref, "columns");
        if (list.len(cols_hmt) > 1) {
            let first_col_hmt = list.get(cols_hmt, 0);
            let second_col_hmt = list.get(cols_hmt, 1);
            if (map.has(first_col_hmt, "tasks")) {
                let tasks_hmt = map.get(first_col_hmt, "tasks");
                if (list.len(tasks_hmt) > 0) {
                    let task_hmt_ref = list.get(tasks_hmt, 0);
                    if (map.has(task_hmt_ref, "id")) {
                        let tid_hmt = map.get(task_hmt_ref, "id");
                        let from_hmt = "";
                        let to_hmt = "";
                        if (map.has(first_col_hmt, "name")) {
                            from_hmt = map.get(first_col_hmt, "name");
                        }
                        if (map.has(second_col_hmt, "name")) {
                            to_hmt = map.get(second_col_hmt, "name");
                        }
                        boards_hmt = simple_move_task(boards_hmt, board_global_id, tid_hmt, from_hmt, to_hmt);
                        print("Moved task to", to_hmt);
                    }
                }
            }
        }
    }
    return boards_hmt;
}

fn handle_delete_task_ui(boards_hdlt) {
    if (list.len(boards_hdlt) == 0) {
        print("No boards.");
        return boards_hdlt;
    }
    let board_hdlt_ref = list.get(boards_hdlt, 0);
    if (map.has(board_hdlt_ref, "id")) {
        boards_hdlt = delete_task_simple(boards_hdlt, map.get(board_hdlt_ref, "id"), 1);
        print("Deleted task ID 1.");
    }
    return boards_hdlt;
}

fn handle_search_ui(boards_hsu) {
