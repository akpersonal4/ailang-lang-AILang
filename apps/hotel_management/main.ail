    if (map.has(report_map, "avg_revenue")) { avg = map.get(report_map, "avg_revenue") }

    io.writeln("=== Revenue Report ===");
    io.writeln(string.concat("Period: ", string.concat(start, string.concat(" to ", end))));
    io.writeln(string.concat("Total Revenue: ", str_to_string(rev)));
    io.writeln(string.concat("Bookings:      ", str_to_string(cnt)));
