    if (map.has(report_map, "reserved")) { res = map.get(report_map, "reserved") }
    if (map.has(report_map, "checked_in")) { cin = map.get(report_map, "checked_in") }
    if (map.has(report_map, "checked_out")) { cout = map.get(report_map, "checked_out") }
