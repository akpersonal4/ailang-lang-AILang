    io.writeln(string.concat("Reserved:    ", str_to_string(res)));
    io.writeln(string.concat("Checked In:  ", str_to_string(cin)));
    io.writeln(string.concat("Checked Out: ", str_to_string(cout)));
    io.writeln(string.concat("Cancelled:   ", str_to_string(can)));
    return 0
}

fn report_utilization() {
    let rooms = load_rooms();
    let total_rooms = list.len(rooms);
    let available = room_filter_by_status(rooms, "AVAILABLE", 0, list.new());
    let occupied = room_filter_by_status(rooms, "OCCUPIED", 0, list.new());
    let maintenance = room_filter_by_status(rooms, "MAINTENANCE", 0, list.new());
    let reserved = room_filter_by_status(rooms, "RESERVED", 0, list.new());
    let result = map.new();
    map.set(result, "total", total_rooms);
    map.set(result, "available", list.len(available));
    map.set(result, "occupied", list.len(occupied));
    map.set(result, "maintenance", list.len(maintenance));
    map.set(result, "reserved", list.len(reserved));
    return result
}

fn report_utilization_display(report_map) {
    let total = 0;
    let avail = 0;
    let occ = 0;
    let maint = 0;
    let res = 0;
    if (map.has(report_map, "total")) { total = map.get(report_map, "total") }
    if (map.has(report_map, "available")) { avail = map.get(report_map, "available") }
    if (map.has(report_map, "occupied")) { occ = map.get(report_map, "occupied") }
    if (map.has(report_map, "maintenance")) { maint = map.get(report_map, "maintenance") }
    if (map.has(report_map, "reserved")) { res = map.get(report_map, "reserved") }

    io.writeln("=== Room Utilization ===");
    io.writeln(string.concat("Total:       ", str_to_string(total)));
    io.writeln(string.concat("Available:   ", str_to_string(avail)));
    io.writeln(string.concat("Occupied:    ", str_to_string(occ)));
    io.writeln(string.concat("Reserved:    ", str_to_string(res)));
    io.writeln(string.concat("Maintenance: ", str_to_string(maint)));
    return 0
}

// ============================================================
// Level 10: Display utilities for list display
// ============================================================

fn display_room_list(rooms, i) {
    if (i >= list.len(rooms)) { return 0 }
    let r = list.get(rooms, i);
    let id = "?";
    let type_val = "?";
    let rate_val = "?";
    let cap_val = "?";
    let status_val = "?";
    if (map.has(r, "id")) { id = str_to_string(map.get(r, "id")) }
    if (map.has(r, "type")) { type_val = str_to_string(map.get(r, "type")) }
    if (map.has(r, "rate")) { rate_val = str_to_string(map.get(r, "rate")) }
    if (map.has(r, "capacity")) { cap_val = str_to_string(map.get(r, "capacity")) }
    if (map.has(r, "status")) { status_val = str_to_string(map.get(r, "status")) }
    io.writeln(string.concat(id, string.concat(" | ", string.concat(type_val, string.concat(" | Rate: ", string.concat(rate_val, string.concat(" | Cap: ", string.concat(cap_val, string.concat(" | ", status_val)))))))));
    return display_room_list(rooms, i + 1)
}

fn display_guest_list(guests, i) {
    if (i >= list.len(guests)) { return 0 }
    let g = list.get(guests, i);
    let id = "?";
    let name = "?";
    let phone = "?";
    let email = "?";
    if (map.has(g, "id")) { id = str_to_string(map.get(g, "id")) }
    if (map.has(g, "name")) { name = str_to_string(map.get(g, "name")) }
    if (map.has(g, "phone")) { phone = str_to_string(map.get(g, "phone")) }
    if (map.has(g, "email")) { email = str_to_string(map.get(g, "email")) }
    io.writeln(string.concat(id, string.concat(" | ", string.concat(name, string.concat(" | ", string.concat(phone, string.concat(" | ", email)))))));
    return display_guest_list(guests, i + 1)
}

fn display_booking_list(bookings, i) {
    if (i >= list.len(bookings)) { return 0 }
    let b = list.get(bookings, i);
    let id = "?";
    let gid = "?";
    let rid = "?";
    let ci = "?";
    let co = "?";
    let st = "?";
    let total = "?";
    if (map.has(b, "id")) { id = str_to_string(map.get(b, "id")) }
    if (map.has(b, "guest_id")) { gid = str_to_string(map.get(b, "guest_id")) }
    if (map.has(b, "room_id")) { rid = str_to_string(map.get(b, "room_id")) }
    if (map.has(b, "check_in")) { ci = str_to_string(map.get(b, "check_in")) }
    if (map.has(b, "check_out")) { co = str_to_string(map.get(b, "check_out")) }
    if (map.has(b, "status")) { st = str_to_string(map.get(b, "status")) }
    if (map.has(b, "total")) { total = str_to_string(map.get(b, "total")) }
    io.writeln(string.concat(id, string.concat(" | G:", string.concat(gid, string.concat(" R:", string.concat(rid, string.concat(" | ", string.concat(ci, string.concat(" to ", string.concat(co, string.concat(" | ", string.concat(st, string.concat(" | $", total)))))))))))));
    return display_booking_list(bookings, i + 1)
}

fn display_payment_list(payments, i) {
    if (i >= list.len(payments)) { return 0 }
    let p = list.get(payments, i);
    let id = "?";
    let bid = "?";
    let amt = "?";
    let method_val = "?";
    let st = "?";
    if (map.has(p, "id")) { id = str_to_string(map.get(p, "id")) }
    if (map.has(p, "booking_id")) { bid = str_to_string(map.get(p, "booking_id")) }
    if (map.has(p, "amount")) { amt = str_to_string(map.get(p, "amount")) }
    if (map.has(p, "method")) { method_val = str_to_string(map.get(p, "method")) }
    if (map.has(p, "status")) { st = str_to_string(map.get(p, "status")) }
    io.writeln(string.concat(id, string.concat(" | B:", string.concat(bid, string.concat(" | $", string.concat(amt, string.concat(" | ", string.concat(method_val, string.concat(" | ", st)))))))));
    return display_payment_list(payments, i + 1)
}

fn display_room_header() {
    io.writeln("ID    | Type       | Rate   | Cap | Status");
    io.writeln("------+------------+--------+-----+--------");
    return 0
}

fn display_guest_header() {
    io.writeln("ID    | Name               | Phone      | Email");
    io.writeln("------+--------------------+------------+------------------");
    return 0
}

fn display_booking_header() {
    io.writeln("ID    | Guest | Room | Check In   | Check Out  | Status        | Total");
    io.writeln("------+-------+------+------------+------------+---------------+-------");
    return 0
}

