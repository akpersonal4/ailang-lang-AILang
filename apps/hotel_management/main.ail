    io.writeln("------+---------+--------+--------+--------");
    return 0
}

// ============================================================
// Level 11: Main — CLI entry point and command routing
// ============================================================

fn cmd_room_add(args, arg_idx) {
    if (list.len(args) < arg_idx + 3) { return "Usage: room add <id> <type> <rate> <capacity>" }
    let id_val = list.get(args, arg_idx);
    let type_val = to_upper(list.get(args, arg_idx + 1));
    let rate_val = string_to_int_safe(list.get(args, arg_idx + 2));
    let cap_val = 2;
    if (list.len(args) > arg_idx + 3) { cap_val = string_to_int_safe(list.get(args, arg_idx + 3)) }
    return room_create(id_val, type_val, rate_val, cap_val)
}

fn cmd_room_list() {
    let rooms = room_list_all();
    if (list.len(rooms) == 0) { return "No rooms found" }
    display_room_header();
    display_room_list(rooms, 0);
    return string.concat(str_to_string(list.len(rooms)), " room(s)")
}

fn cmd_room_update_rate(args, arg_idx) {
    if (list.len(args) < arg_idx + 2) { return "Usage: room update-rate <id> <new_rate>" }
    let id_val = list.get(args, arg_idx);
    let rate_val = string_to_int_safe(list.get(args, arg_idx + 1));
    return room_update_rate(id_val, rate_val)
}

fn cmd_room_set_status(args, arg_idx) {
    if (list.len(args) < arg_idx + 2) { return "Usage: room set-status <id> <status>" }
    let id_val = list.get(args, arg_idx);
    let status_val = to_upper(list.get(args, arg_idx + 1));
    return room_set_status(id_val, status_val)
}

fn cmd_room_available(args, arg_idx) {
    if (list.len(args) < arg_idx + 2) { return "Usage: room available <check_in> <check_out>" }
    let ci = list.get(args, arg_idx);
    let co = list.get(args, arg_idx + 1);
    if (!validate_date_format(ci)) { return "Error: Invalid check-in date (use YYYY-MM-DD)" }
    if (!validate_date_format(co)) { return "Error: Invalid check-out date (use YYYY-MM-DD)" }
    if (!is_date_before(ci, co)) { return "Error: Check-in must be before check-out" }
    let rooms = load_rooms();
    let available = room_available_on_dates(rooms, ci, co, 0, list.new());
    if (list.len(available) == 0) { return "No available rooms for those dates" }
    display_room_header();
    display_room_list(available, 0);
    return string.concat(str_to_string(list.len(available)), " available room(s)")
}

fn cmd_room_dispatch(args, arg_idx) {
    if (arg_idx >= list.len(args)) { return "Error: Missing room subcommand" }
    let sub = to_upper(list.get(args, arg_idx));
    if (string.equals(sub, "ADD")) { return cmd_room_add(args, arg_idx + 1) }
    if (string.equals(sub, "LIST")) { return cmd_room_list() }
    if (string.equals(sub, "UPDATE-RATE") || string.equals(sub, "UPDATERATE")) {
        return cmd_room_update_rate(args, arg_idx + 1)
    }
    if (string.equals(sub, "SET-STATUS") || string.equals(sub, "SETSTATUS")) {
        return cmd_room_set_status(args, arg_idx + 1)
    }
    if (string.equals(sub, "AVAILABLE")) { return cmd_room_available(args, arg_idx + 1) }
    return string.concat("Error: Unknown room subcommand: ", sub)
}

fn cmd_guest_add(args, arg_idx) {
    if (list.len(args) < arg_idx + 2) { return "Usage: guest add <name> <phone> [email]" }
    let name_val = list.get(args, arg_idx);
    let phone_val = list.get(args, arg_idx + 1);
    let email_val = "";
    if (list.len(args) > arg_idx + 2) { email_val = list.get(args, arg_idx + 2) }
    return guest_create(name_val, phone_val, email_val)
}

fn cmd_guest_search(args, arg_idx) {
    if (arg_idx >= list.len(args)) { return "Usage: guest search <name>" }
    let query = list.get(args, arg_idx);
    let results = guest_search_by_name(query);
    if (list.len(results) == 0) { return "No guests found matching that name" }
    display_guest_header();
    display_guest_list(results, 0);
    return string.concat(str_to_string(list.len(results)), " guest(s) found")
}

fn cmd_guest_list() {
    let guests = guest_list_all();
    if (list.len(guests) == 0) { return "No guests registered" }
    display_guest_header();
    display_guest_list(guests, 0);
    return string.concat(str_to_string(list.len(guests)), " guest(s)")
}

fn cmd_guest_dispatch(args, arg_idx) {
    if (arg_idx >= list.len(args)) { return "Error: Missing guest subcommand" }
    let sub = to_upper(list.get(args, arg_idx));
    if (string.equals(sub, "ADD")) { return cmd_guest_add(args, arg_idx + 1) }
    if (string.equals(sub, "SEARCH")) { return cmd_guest_search(args, arg_idx + 1) }
    if (string.equals(sub, "LIST")) { return cmd_guest_list() }
    return string.concat("Error: Unknown guest subcommand: ", sub)
}

fn cmd_booking_create(args, arg_idx) {
    if (list.len(args) < arg_idx + 4) {
        return "Usage: booking create <guest_id> <room_id> <check_in> <check_out> [guests]"
    }
    let guest_id = list.get(args, arg_idx);
    let room_id = list.get(args, arg_idx + 1);
    let check_in = list.get(args, arg_idx + 2);
    let check_out = list.get(args, arg_idx + 3);
    let guests_count = 1;
    if (list.len(args) > arg_idx + 4) { guests_count = string_to_int_safe(list.get(args, arg_idx + 4)) }

    if (!validate_date_format(check_in)) { return "Error: Invalid check-in date (use YYYY-MM-DD)" }
    if (!validate_date_format(check_out)) { return "Error: Invalid check-out date (use YYYY-MM-DD)" }

    return booking_create(guest_id, room_id, check_in, check_out, guests_count)
}

fn cmd_booking_checkin(args, arg_idx) {
    if (arg_idx >= list.len(args)) { return "Usage: booking checkin <booking_id>" }
    return booking_check_in(list.get(args, arg_idx))
}

fn cmd_booking_checkout(args, arg_idx) {
    if (arg_idx >= list.len(args)) { return "Usage: booking checkout <booking_id>" }
    return booking_check_out(list.get(args, arg_idx))
}

fn cmd_booking_cancel(args, arg_idx) {
    if (arg_idx >= list.len(args)) { return "Usage: booking cancel <booking_id>" }
    return booking_cancel(list.get(args, arg_idx))
}

fn cmd_booking_detail(args, arg_idx) {
    if (arg_idx >= list.len(args)) { return "Usage: booking detail <booking_id>" }
    let bk = booking_find_by_id(list.get(args, arg_idx));
    let none = json.parse("null");
    if (string.equals(str_to_string(bk), str_to_string(none))) { return "Error: Booking not found" }
    let display_list = list.new();
    list.append(display_list, bk);
    display_booking_header();
    display_booking_list(display_list, 0);
    let inv = invoice_generate(list.get(args, arg_idx));
    invoice_display(inv);
    return ""
}

fn cmd_booking_list() {
    let bookings = booking_list_all();
    if (list.len(bookings) == 0) { return "No bookings" }
    display_booking_header();
    display_booking_list(bookings, 0);
    return string.concat(str_to_string(list.len(bookings)), " booking(s)")
}

fn cmd_booking_dispatch(args, arg_idx) {
    if (arg_idx >= list.len(args)) { return "Error: Missing booking subcommand" }
    let sub = to_upper(list.get(args, arg_idx));
    if (string.equals(sub, "CREATE")) { return cmd_booking_create(args, arg_idx + 1) }
    if (string.equals(sub, "CHECKIN") || string.equals(sub, "CHECK-IN")) {
        return cmd_booking_checkin(args, arg_idx + 1)
    }
    if (string.equals(sub, "CHECKOUT") || string.equals(sub, "CHECK-OUT")) {
        return cmd_booking_checkout(args, arg_idx + 1)
    }
    if (string.equals(sub, "CANCEL")) { return cmd_booking_cancel(args, arg_idx + 1) }
    if (string.equals(sub, "DETAIL")) { return cmd_booking_detail(args, arg_idx + 1) }
    if (string.equals(sub, "LIST")) { return cmd_booking_list() }
    return string.concat("Error: Unknown booking subcommand: ", sub)
}

fn cmd_payment_record(args, arg_idx) {
    if (list.len(args) < arg_idx + 2) {
        return "Usage: payment record <booking_id> <amount> [method]"
    }
    let booking_id = list.get(args, arg_idx);
    let amount_val = string_to_int_safe(list.get(args, arg_idx + 1));
    let method_val = "CASH";
    if (list.len(args) > arg_idx + 2) { method_val = to_upper(list.get(args, arg_idx + 2)) }
    return payment_record(booking_id, amount_val, method_val)
}

fn cmd_payment_view(args, arg_idx) {
    if (arg_idx >= list.len(args)) { return "Usage: payment view <booking_id>" }
    let payments = payment_list_by_booking(list.get(args, arg_idx));
    if (list.len(payments) == 0) { return "No payments for this booking" }
    display_payment_header();
    display_payment_list(payments, 0);
    let sum = payment_sum_for_booking(list.get(args, arg_idx));
    return string.concat("Total payments: ", str_to_string(sum))
}

fn cmd_payment_dispatch(args, arg_idx) {
    if (arg_idx >= list.len(args)) { return "Error: Missing payment subcommand" }
    let sub = to_upper(list.get(args, arg_idx));
    if (string.equals(sub, "RECORD")) { return cmd_payment_record(args, arg_idx + 1) }
    if (string.equals(sub, "VIEW")) { return cmd_payment_view(args, arg_idx + 1) }
    return string.concat("Error: Unknown payment subcommand: ", sub)
}

fn cmd_report_occupancy(args, arg_idx) {
    if (list.len(args) < arg_idx + 2) {
        return "Usage: report occupancy <start_date> <end_date>"
    }
    let start = list.get(args, arg_idx);
    let end = list.get(args, arg_idx + 1);
    if (!validate_date_format(start)) { return "Error: Invalid start date" }
    if (!validate_date_format(end)) { return "Error: Invalid end date" }
    let r = report_occupancy(start, end);
    report_occupancy_display(r);
    return ""
}

fn cmd_report_revenue(args, arg_idx) {
    if (list.len(args) < arg_idx + 2) {
        return "Usage: report revenue <start_date> <end_date>"
    }
    let start = list.get(args, arg_idx);
    let end = list.get(args, arg_idx + 1);
    if (!validate_date_format(start)) { return "Error: Invalid start date" }
    if (!validate_date_format(end)) { return "Error: Invalid end date" }
    let r = report_revenue(start, end);
    report_revenue_display(r);
    return ""
}

fn cmd_report_bookings() {
    let r = report_booking_summary();
    report_booking_summary_display(r);
    return ""
}

fn cmd_report_utilization() {
    let r = report_utilization();
    report_utilization_display(r);
    return ""
}

fn cmd_report_dispatch(args, arg_idx) {
    if (arg_idx >= list.len(args)) { return "Error: Missing report subcommand" }
    let sub = to_upper(list.get(args, arg_idx));
    if (string.equals(sub, "OCCUPANCY")) { return cmd_report_occupancy(args, arg_idx + 1) }
    if (string.equals(sub, "REVENUE")) { return cmd_report_revenue(args, arg_idx + 1) }
    if (string.equals(sub, "BOOKINGS") || string.equals(sub, "SUMMARY")) {
        return cmd_report_bookings()
    }
    if (string.equals(sub, "UTILIZATION")) { return cmd_report_utilization() }
    return string.concat("Error: Unknown report subcommand: ", sub)
}

fn cmd_invoice_dispatch(args, arg_idx) {
    if (arg_idx >= list.len(args)) { return "Usage: invoice <booking_id>" }
    let booking_id = list.get(args, arg_idx);
    let inv = invoice_generate(booking_id);
    if (map.has(inv, "guest_name")) {
        invoice_display(inv);
        return ""
    }
    return str_to_string(inv)
}

fn show_usage() {
    io.writeln("Hotel Management System for AILang");
    io.writeln("");
    io.writeln("Room Commands:");
    io.writeln("  room add <id> <type> <rate> [capacity]");
    io.writeln("  room list");
    io.writeln("  room update-rate <id> <new_rate>");
    io.writeln("  room set-status <id> <status>");
    io.writeln("  room available <check_in> <check_out>");
    io.writeln("");
    io.writeln("Guest Commands:");
    io.writeln("  guest add <name> <phone> [email]");
    io.writeln("  guest search <name>");
    io.writeln("  guest list");
    io.writeln("");
    io.writeln("Booking Commands:");
    io.writeln("  booking create <guest_id> <room_id> <check_in> <check_out> [guests]");
    io.writeln("  booking checkin <id>");
    io.writeln("  booking checkout <id>");
    io.writeln("  booking cancel <id>");
    io.writeln("  booking detail <id>");
    io.writeln("  booking list");
    io.writeln("");
    io.writeln("Payment Commands:");
    io.writeln("  payment record <booking_id> <amount> [method]");
    io.writeln("  payment view <booking_id>");
    io.writeln("");
    io.writeln("Report Commands:");
    io.writeln("  report occupancy <start_date> <end_date>");
    io.writeln("  report revenue <start_date> <end_date>");
    io.writeln("  report bookings");
    io.writeln("  report utilization");
    io.writeln("");
    io.writeln("Invoice Commands:");
    io.writeln("  invoice <booking_id>");
    return 0
}

fn main() {
    let args = environment.args();
    if (list.len(args) < 1) {
        show_usage();
        return 0
    }
    let cmd = to_upper(list.get(args, 0));
    let result = "";
    if (string.equals(cmd, "ROOM")) { result = cmd_room_dispatch(args, 1) }
    else if (string.equals(cmd, "GUEST")) { result = cmd_guest_dispatch(args, 1) }
    else if (string.equals(cmd, "BOOKING")) { result = cmd_booking_dispatch(args, 1) }
    else if (string.equals(cmd, "PAYMENT")) { result = cmd_payment_dispatch(args, 1) }
    else if (string.equals(cmd, "REPORT")) { result = cmd_report_dispatch(args, 1) }
    else if (string.equals(cmd, "INVOICE")) { result = cmd_invoice_dispatch(args, 1) }
    else if (string.equals(cmd, "HELP") || string.equals(cmd, "--HELP") || string.equals(cmd, "-H")) {
        show_usage();
        return 0
    }
    else {
        show_usage();
        return 0
    }
    if (!string.equals(result, "")) {
        io.writeln(result)
    }
    return 0
}
