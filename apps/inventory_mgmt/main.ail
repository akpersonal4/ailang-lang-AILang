}

fn calculate_inventory_value_helper(inv_cvh, pos_cvh, acc_cvh) {
    if (!map.has(inv_cvh, "items")) {
        return acc_cvh;
    }
    let items_cvh = map.get(inv_cvh, "items");
    let len_cvh = list.len(items_cvh);
    if (pos_cvh >= len_cvh) {
        return acc_cvh;
    }
    let item_cvh = list.get(items_cvh, pos_cvh);
    let qty_cvh = 0;
    let price_cvh = 0;
    if (map.has(item_cvh, "quantity")) {
        qty_cvh = map.get(item_cvh, "quantity");
    }
    if (map.has(item_cvh, "unit_price")) {
        price_cvh = map.get(item_cvh, "unit_price");
    }
    let val_cvh = math.mul(qty_cvh, price_cvh);
    return calculate_inventory_value_helper(inv_cvh, pos_cvh + 1, acc_cvh + val_cvh);
}

fn calculate_inventory_value(inv_civ) {
    return calculate_inventory_value_helper(inv_civ, 0, 0);
}

fn get_category_inventory_helper(inv_gcih, pos_gcih, result_gcih) {
    if (!map.has(inv_gcih, "items")) {
        return result_gcih;
    }
    let items_gcih = map.get(inv_gcih, "items");
    let len_gcih = list.len(items_gcih);
    if (pos_gcih >= len_gcih) {
        return result_gcih;
    }
    let item_gcih = list.get(items_gcih, pos_gcih);
    let cat_id_gcih = 0;
    if (map.has(item_gcih, "category_id")) {
        cat_id_gcih = map.get(item_gcih, "category_id");
    }
    let qty_gcih = 0;
    if (map.has(item_gcih, "quantity")) {
        qty_gcih = map.get(item_gcih, "quantity");
    }
    let price_gcih = 0;
    if (map.has(item_gcih, "unit_price")) {
        price_gcih = map.get(item_gcih, "unit_price");
    }
    let cat_key_gcih = int_to_string(cat_id_gcih);
    let cur_val_gcih = 0;
    if (map.has(result_gcih, cat_key_gcih)) {
        cur_val_gcih = map.get(result_gcih, cat_key_gcih);
    }
    let new_val_gcih = math.mul(qty_gcih, price_gcih);
    map.set(result_gcih, cat_key_gcih, cur_val_gcih + new_val_gcih);
    return get_category_inventory_helper(inv_gcih, pos_gcih + 1, result_gcih);
}

fn get_category_inventory(inv_gci) {
    return get_category_inventory_helper(inv_gci, 0, map.new());
}

// ============================================================
// Level 4: Persistence
// ============================================================
fn inventory_to_full_map(inv_im, cats_im, supps_im) {
    let data_im = map.new();
    let stored_items_im = list.new();
    if (map.has(inv_im, "items")) {
        let items_im = map.get(inv_im, "items");
        let len_im = list.len(items_im);
        let pos_im = 0;
        if (len_im > 0) {
            stored_items_im = list_copy(items_im, stored_items_im, 0);
        }
    }
    map.set(data_im, "items", stored_items_im);
    let stored_cats_im = list.new();
    let cats_len_im = list.len(cats_im);
    if (cats_len_im > 0) {
        stored_cats_im = list_copy(cats_im, stored_cats_im, 0);
    }
    map.set(data_im, "categories", stored_cats_im);
    let stored_supps_im = list.new();
    let supps_len_im = list.len(supps_im);
    if (supps_len_im > 0) {
        stored_supps_im = list_copy(supps_im, stored_supps_im, 0);
    }
    map.set(data_im, "suppliers", stored_supps_im);
    let stored_txns_im = list.new();
    if (map.has(inv_im, "transactions")) {
        let txns_im = map.get(inv_im, "transactions");
        let txns_len_im = list.len(txns_im);
        if (txns_len_im > 0) {
            stored_txns_im = list_copy(txns_im, stored_txns_im, 0);
        }
    }
    map.set(data_im, "transactions", stored_txns_im);
    return data_im;
}

fn build_items_from_data(data_bif, pos_bif, result_bif) {
    if (!map.has(data_bif, "items")) {
        return result_bif;
    }
    let items_bif = map.get(data_bif, "items");
    let len_bif = list.len(items_bif);
    if (pos_bif >= len_bif) {
        return result_bif;
    }
    let raw_bif = list.get(items_bif, pos_bif);
    let item_bif = map_to_item(raw_bif);
    list.append(result_bif, item_bif);
    return build_items_from_data(data_bif, pos_bif + 1, result_bif);
}

fn build_categories_from_data(data_bcf, pos_bcf, result_bcf) {
    if (!map.has(data_bcf, "categories")) {
        return result_bcf;
    }
    let cats_bcf = map.get(data_bcf, "categories");
    let len_bcf = list.len(cats_bcf);
    if (pos_bcf >= len_bcf) {
        return result_bcf;
    }
    let raw_bcf = list.get(cats_bcf, pos_bcf);
    let cat_bcf = map_to_category(raw_bcf);
    list.append(result_bcf, cat_bcf);
    return build_categories_from_data(data_bcf, pos_bcf + 1, result_bcf);
}

fn build_suppliers_from_data(data_bsf, pos_bsf, result_bsf) {
    if (!map.has(data_bsf, "suppliers")) {
        return result_bsf;
    }
    let supps_bsf = map.get(data_bsf, "suppliers");
    let len_bsf = list.len(supps_bsf);
    if (pos_bsf >= len_bsf) {
        return result_bsf;
    }
    let raw_bsf = list.get(supps_bsf, pos_bsf);
    let supp_bsf = map_to_supplier(raw_bsf);
    list.append(result_bsf, supp_bsf);
    return build_suppliers_from_data(data_bsf, pos_bsf + 1, result_bsf);
}

fn build_transactions_from_data(data_btf, pos_btf, result_btf) {
    if (!map.has(data_btf, "transactions")) {
        return result_btf;
    }
    let txns_btf = map.get(data_btf, "transactions");
    let len_btf = list.len(txns_btf);
    if (pos_btf >= len_btf) {
        return result_btf;
    }
    let raw_btf = list.get(txns_btf, pos_btf);
    let txn_btf = map_to_transaction(raw_btf);
    list.append(result_btf, txn_btf);
    return build_transactions_from_data(data_btf, pos_btf + 1, result_btf);
}

fn full_map_to_inventory(data_fmi) {
    let inv_fmi = map.new();
    let items_fmi = build_items_from_data(data_fmi, 0, list.new());
    map.set(inv_fmi, "items", items_fmi);
    let cats_fmi = build_categories_from_data(data_fmi, 0, list.new());
    let supps_fmi = build_suppliers_from_data(data_fmi, 0, list.new());
    let txns_fmi = build_transactions_from_data(data_fmi, 0, list.new());
    map.set(inv_fmi, "categories", cats_fmi);
    map.set(inv_fmi, "suppliers", supps_fmi);
    map.set(inv_fmi, "transactions", txns_fmi);
    return inv_fmi;
}

fn save_inventory_file(filepath_sf, inv_sf, cats_sf, supps_sf) {
    let data_sf = inventory_to_full_map(inv_sf, cats_sf, supps_sf);
    let text_sf = json.stringify(data_sf);
    file.write(filepath_sf, text_sf);
    return 0;
}

fn load_inventory_file(filepath_lf) {
    if (!file.exists(filepath_lf)) {
        return map.new();
    }
    let content_lf = file.read(filepath_lf);
    let len_lf = string.length(content_lf);
    if (len_lf == 0) {
        return map.new();
    }
    let data_lf = json.parse(content_lf);
    return full_map_to_inventory(data_lf);
}

// ============================================================
// Level 5: Display & Reports
// ============================================================
fn print_item_info(item_pi) {
    if (!map.has(item_pi, "id")) {
        return 0;
    }
    let id_pi = map.get(item_pi, "id");
    let sku_pi = "";
    let name_pi = "";
    let qty_pi = 0;
    let price_pi = 0;
    if (map.has(item_pi, "sku")) {
        sku_pi = map.get(item_pi, "sku");
    }
    if (map.has(item_pi, "name")) {
        name_pi = map.get(item_pi, "name");
    }
    if (map.has(item_pi, "quantity")) {
        qty_pi = map.get(item_pi, "quantity");
    }
    if (map.has(item_pi, "unit_price")) {
        price_pi = map.get(item_pi, "unit_price");
    }
    let id_str_pi = int_to_string(id_pi);
    let qty_str_pi = int_to_string(qty_pi);
    let price_str_pi = int_to_string(price_pi);
    print("  #" + id_str_pi + ":", "[" + sku_pi + "]", name_pi, "Qty:", qty_str_pi, "Price:", price_str_pi);
    return 0;
}

fn print_items_list(items_pil, pos_pil) {
    let len_pil = list.len(items_pil);
    if (pos_pil >= len_pil) {
        return 0;
    }
    let item_pil = list.get(items_pil, pos_pil);
    print_item_info(item_pil);
    return print_items_list(items_pil, pos_pil + 1);
}

fn print_category_info(cat_pci) {
    if (!map.has(cat_pci, "id")) {
        return 0;
    }
    let id_pci = map.get(cat_pci, "id");
    let name_pci = "";
    if (map.has(cat_pci, "name")) {
        name_pci = map.get(cat_pci, "name");
    }
    let id_str_pci = int_to_string(id_pci);
    print("  [" + id_str_pci + "]", name_pci);
    return 0;
}

fn print_categories_list(cats_pcl, pos_pcl) {
    let len_pcl = list.len(cats_pcl);
    if (pos_pcl >= len_pcl) {
        return 0;
    }
    let cat_pcl = list.get(cats_pcl, pos_pcl);
    print_category_info(cat_pcl);
    return print_categories_list(cats_pcl, pos_pcl + 1);
}

fn print_supplier_info(supp_psi) {
    if (!map.has(supp_psi, "id")) {
        return 0;
    }
    let id_psi = map.get(supp_psi, "id");
    let name_psi = "";
    let contact_psi = "";
    if (map.has(supp_psi, "name")) {
        name_psi = map.get(supp_psi, "name");
    }
    if (map.has(supp_psi, "contact")) {
        contact_psi = map.get(supp_psi, "contact");
    }
    let id_str_psi = int_to_string(id_psi);
    print("  #" + id_str_psi + ": " + name_psi + " (" + contact_psi + ")");
    return 0;
}

fn print_suppliers_list(supps_psl, pos_psl) {
    let len_psl = list.len(supps_psl);
    if (pos_psl >= len_psl) {
        return 0;
    }
    let supp_psl = list.get(supps_psl, pos_psl);
    print_supplier_info(supp_psl);
    return print_suppliers_list(supps_psl, pos_psl + 1);
}

fn print_inventory_summary(inv_pis, cats_pis) {
    print("");
    print("=== Inventory Summary ===");
    let total_items_pis = 0;
    if (map.has(inv_pis, "items")) {
        total_items_pis = list.len(map.get(inv_pis, "items"));
    }
    let total_txns_pis = 0;
    if (map.has(inv_pis, "transactions")) {
        total_txns_pis = list.len(map.get(inv_pis, "transactions"));
    }
    let total_cats_pis = list.len(cats_pis);
    let total_val_pis = calculate_inventory_value(inv_pis);
    print("  Items:", int_to_string(total_items_pis));
    print("  Categories:", int_to_string(total_cats_pis));
    print("  Transactions:", int_to_string(total_txns_pis));
    print("  Total Inventory Value:", int_to_string(total_val_pis));
    return 0;
}

fn print_low_stock_report(inv_plr) {
    print("");
    print("=== Low Stock Alert ===");
    let low_items_plr = get_low_stock_items(inv_plr);
    let low_len_plr = list.len(low_items_plr);
    if (low_len_plr == 0) {
        print("  No items below minimum quantity.");
        return 0;
    }
    print("  Items below minimum quantity:", int_to_string(low_len_plr));
    print_items_list(low_items_plr, 0);
    return 0;
}

fn print_category_name(cat_id_pcn, cats_pcn, pos_pcn) {
    let len_pcn = list.len(cats_pcn);
    if (pos_pcn >= len_pcn) {
        return "Unknown";
    }
    let cat_pcn = list.get(cats_pcn, pos_pcn);
    if (map.has(cat_pcn, "id")) {
        if (map.get(cat_pcn, "id") == cat_id_pcn) {
            if (map.has(cat_pcn, "name")) {
                return map.get(cat_pcn, "name");
            }
        }
    }
    return print_category_name(cat_id_pcn, cats_pcn, pos_pcn + 1);
}

fn print_category_breakdown_iter(inv_pcbi, cats_pcbi, cat_inv_pcbi, keys_pcbi, pos_pcbi) {
    let len_pcbi = list.len(keys_pcbi);
    if (pos_pcbi >= len_pcbi) {
        return 0;
    }
    let key_pcbi = list.get(keys_pcbi, pos_pcbi);
    let cat_id_int_pcbi = convert.to_int(key_pcbi);
    let cat_name_pcbi = print_category_name(cat_id_int_pcbi, cats_pcbi, 0);
    let cat_val_pcbi = 0;
    if (map.has(cat_inv_pcbi, key_pcbi)) {
        cat_val_pcbi = map.get(cat_inv_pcbi, key_pcbi);
    }
    let cat_val_str_pcbi = int_to_string(cat_val_pcbi);
    print("  " + cat_name_pcbi + ": $" + cat_val_str_pcbi);
    return print_category_breakdown_iter(inv_pcbi, cats_pcbi, cat_inv_pcbi, keys_pcbi, pos_pcbi + 1);
}

fn print_category_breakdown(inv_pcb, cats_pcb) {
    print("");
    print("=== Category Breakdown ===");
    let cat_inv_pcb = get_category_inventory(inv_pcb);
    let cat_keys_pcb = map.keys(cat_inv_pcb);
    let key_len_pcb = list.len(cat_keys_pcb);
    if (key_len_pcb == 0) {
        print("  No items in inventory.");
        return 0;
    }
    let pos_pcb = 0;
    if (key_len_pcb > 0) {
        let cat_name_pcb = "";
        let cat_val_pcb = 0;
        let key_pcb = list.get(cat_keys_pcb, pos_pcb);
        let cat_id_int_pcb = convert.to_int(key_pcb);
        cat_name_pcb = print_category_name(cat_id_int_pcb, cats_pcb, 0);
        if (map.has(cat_inv_pcb, key_pcb)) {
            cat_val_pcb = map.get(cat_inv_pcb, key_pcb);
        }
        let cat_val_str_pcb = int_to_string(cat_val_pcb);
        print("  " + cat_name_pcb + ": $" + cat_val_str_pcb);
        pos_pcb = 1;
    }
    return print_category_breakdown_iter(inv_pcb, cats_pcb, cat_inv_pcb, cat_keys_pcb, pos_pcb);
}

fn print_transaction_info(txn_pti) {
    if (!map.has(txn_pti, "id")) {
        return 0;
    }
    let id_pti = map.get(txn_pti, "id");
    let type_pti = "";
    let qty_pti = 0;
    let note_pti = "";
    if (map.has(txn_pti, "type")) {
        type_pti = map.get(txn_pti, "type");
    }
    if (map.has(txn_pti, "quantity")) {
        qty_pti = map.get(txn_pti, "quantity");
    }
    if (map.has(txn_pti, "note")) {
        note_pti = map.get(txn_pti, "note");
    }
    let id_str_pti = int_to_string(id_pti);
    let qty_str_pti = int_to_string(qty_pti);
    print("  #" + id_str_pti + ":", type_pti, qty_str_pti, "units", "-", note_pti);
    return 0;
}

fn print_item_transaction_history_iter(txns_pthi, pos_pthi) {
    let len_pthi = list.len(txns_pthi);
    if (pos_pthi >= len_pthi) {
        return 0;
    }
    let txn_pthi = list.get(txns_pthi, pos_pthi);
    print_transaction_info(txn_pthi);
    return print_item_transaction_history_iter(txns_pthi, pos_pthi + 1);
}

fn print_item_transaction_history(inv_pth, item_id_pth) {
    print("");
    print("=== Transaction History ===");
    let txns_pth = get_item_transactions(inv_pth, item_id_pth);
    let txn_len_pth = list.len(txns_pth);
    if (txn_len_pth == 0) {
        print("  No transactions found.");
        return 0;
    }
    let pos_pth = 0;
    if (txn_len_pth > 0) {
        let txn_pth = list.get(txns_pth, pos_pth);
        print_transaction_info(txn_pth);
        return print_item_transaction_history_iter(txns_pth, pos_pth + 1);
    }
    return 0;
}

fn print_all_items(inv_pai) {
    if (!map.has(inv_pai, "items")) {
        print("  No items in inventory.");
        return 0;
    }
    let items_pai = map.get(inv_pai, "items");
    let len_pai = list.len(items_pai);
    if (len_pai == 0) {
        print("  No items in inventory.");
        return 0;
    }
    print_items_list(items_pai, 0);
    return 0;
}

fn print_all_report(inv_par, cats_par) {
    print_inventory_summary(inv_par, cats_par);
    print_low_stock_report(inv_par);
    print_category_breakdown(inv_par, cats_par);
    print("");
    print("=== All Items ===");
    print_all_items(inv_par);
    return 0;
}

