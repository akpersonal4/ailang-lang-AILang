fn create_demo_transactions(inv_dt, items_dt) {
    let t1_dt = make_transaction(1001, 101, "purchase", 200, "2026-07-01", "Initial stock");
    record_transaction(inv_dt, t1_dt);
    update_item_stock(inv_dt, 101, 200);
    let t2_dt = make_transaction(1002, 102, "purchase", 100, "2026-07-01", "Initial stock");
    record_transaction(inv_dt, t2_dt);
    update_item_stock(inv_dt, 102, 100);
    let t3_dt = make_transaction(1003, 101, "sale", 50, "2026-07-03", "Online order fulfillment");
    record_transaction(inv_dt, t3_dt);
    update_item_stock(inv_dt, 101, -50);
    let t4_dt = make_transaction(1004, 104, "purchase", 500, "2026-07-01", "Initial stock");
    record_transaction(inv_dt, t4_dt);
    update_item_stock(inv_dt, 104, 500);
    let t5_dt = make_transaction(1005, 105, "sale", 200, "2026-07-05", "Bulk order - School supply");
    record_transaction(inv_dt, t5_dt);
    update_item_stock(inv_dt, 105, -200);
    let t6_dt = make_transaction(1006, 107, "purchase", 60, "2026-07-01", "Initial stock");
    record_transaction(inv_dt, t6_dt);
    update_item_stock(inv_dt, 107, 60);
    let t7_dt = make_transaction(1007, 110, "purchase", 400, "2026-07-01", "Initial stock");
    record_transaction(inv_dt, t7_dt);
    update_item_stock(inv_dt, 110, 400);
    let t8_dt = make_transaction(1008, 106, "sale", 100, "2026-07-04", "Office restock");
    record_transaction(inv_dt, t8_dt);
    update_item_stock(inv_dt, 106, -100);
    return 0;
}

fn load_items(inv_li, items_li, pos_li) {
    let len_li = list.len(items_li);
    if (pos_li >= len_li) {
        return 0;
    }
    let item_li = list.get(items_li, pos_li);
    add_item_to_inventory(inv_li, item_li);
    return load_items(inv_li, items_li, pos_li + 1);
}

fn run_demo() {
    print("Loading demo data...");
    let categories_rd = create_demo_categories();
    let suppliers_rd = create_demo_suppliers();
    let items_rd = create_demo_items(categories_rd, suppliers_rd);
    let inventory_rd = map.new();
    map.set(inventory_rd, "items", list.new());
    map.set(inventory_rd, "transactions", list.new());
    let item_count_rd = list.len(items_rd);
    let pos_rd = 0;
    if (item_count_rd > 0) {
        let item_rd = list.get(items_rd, pos_rd);
        add_item_to_inventory(inventory_rd, item_rd);
        pos_rd = 1;
    }
    let load_result_rd = load_items(inventory_rd, items_rd, pos_rd);
    create_demo_transactions(inventory_rd, items_rd);
    print("");
    print("===================================");
    print("  Inventory Management System Demo");
    print("===================================");
    print("");
    print("Loaded", int_to_string(item_count_rd), "items across", int_to_string(list.len(categories_rd)), "categories");
    print("");
    print("--- Categories ---");
    print_categories_list(categories_rd, 0);
    print("");
    print("--- Suppliers ---");
    print_suppliers_list(suppliers_rd, 0);
    print_all_report(inventory_rd, categories_rd);
    let low_items_rd = get_low_stock_items(inventory_rd);
    if (list.len(low_items_rd) > 0) {
        print("");
        print("WARNING: Low stock items detected!");
    }
    print("");
    print("=== End of Inventory Demo ===");
    save_inventory_file("inventory_data.json", inventory_rd, categories_rd, suppliers_rd);
    print("Data saved to inventory_data.json");
    return 0;
}

// ============================================================
// Level 7: Entry Point
// ============================================================
fn main() {
    return run_demo();
}
