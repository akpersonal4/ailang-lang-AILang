// ============================================================
// Level 0: Leaf utilities — no AILang function dependencies
// ============================================================
fn is_empty(val_ie) {
    if (val_ie == "") {
        return true;
    }
    if (val_ie == 0) {
        return true;
    }
    return false;
}

fn current_timestamp_val() {
    return time.timestamp();
}

fn new_id() {
    return random.int(10000, 99999);
}

fn find_substring(text_fs, pat_fs, start_fs) {
    let text_len_fs = string.length(text_fs);
    let pat_len_fs = string.length(pat_fs);
    if (start_fs + pat_len_fs > text_len_fs) {
        return -1;
    }
    let slice_fs = string.substring(text_fs, start_fs, start_fs + pat_len_fs);
    if (string.equals(slice_fs, pat_fs)) {
        return start_fs;
    }
    return find_substring(text_fs, pat_fs, start_fs + 1);
}

fn find_delim(text_fd, delim_fd, start_fd) {
    return find_substring(text_fd, delim_fd, start_fd);
}

fn split_helper(text_sh, delim_sh, pos_sh, result_sh) {
    let text_len_sh = string.length(text_sh);
    let delim_len_sh = string.length(delim_sh);
    if (pos_sh >= text_len_sh) {
        return result_sh;
    }
    let delim_pos_sh = find_delim(text_sh, delim_sh, pos_sh);
    if (delim_pos_sh == -1) {
        let last_part_sh = string.substring(text_sh, pos_sh, text_len_sh);
        list.append(result_sh, last_part_sh);
        return result_sh;
    }
    let part_sh = string.substring(text_sh, pos_sh, delim_pos_sh);
    list.append(result_sh, part_sh);
    return split_helper(text_sh, delim_sh, delim_pos_sh + delim_len_sh, result_sh);
}

fn split_string(text_ss, delim_ss) {
    return split_helper(text_ss, delim_ss, 0, list.new());
}

fn string_in_list_pos(items_slp, search_slp, pos_slp) {
    let len_slp = list.len(items_slp);
    if (pos_slp >= len_slp) {
        return -1;
    }
    let item_slp = list.get(items_slp, pos_slp);
    if (item_slp == search_slp) {
        return pos_slp;
    }
    return string_in_list_pos(items_slp, search_slp, pos_slp + 1);
}

fn string_in_list_flag(items_slf, search_slf) {
    let pos_slf = string_in_list_pos(items_slf, search_slf, 0);
    if (pos_slf >= 0) {
        return true;
    }
    return false;
}

fn list_copy(items_lc, result_lc, pos_lc) {
    let len_lc = list.len(items_lc);
    if (pos_lc >= len_lc) {
        return result_lc;
    }
    let item_lc = list.get(items_lc, pos_lc);
    list.append(result_lc, item_lc);
    return list_copy(items_lc, result_lc, pos_lc + 1);
}

fn int_to_string(val_its) {
    return convert.to_string(val_its);
}

// ============================================================
// Level 1: Filter / Search utilities
// ============================================================
fn filter_matching(items_fm, field_fm, value_fm, pos_fm, result_fm) {
    let len_fm = list.len(items_fm);
    if (pos_fm >= len_fm) {
        return result_fm;
    }
    let item_fm = list.get(items_fm, pos_fm);
    if (map.has(item_fm, field_fm)) {
        let fv_fm = map.get(item_fm, field_fm);
        if (fv_fm == value_fm) {
            list.append(result_fm, item_fm);
        }
    }
    return filter_matching(items_fm, field_fm, value_fm, pos_fm + 1, result_fm);
}

fn count_matching(items_cm, field_cm, value_cm, pos_cm, acc_cm) {
    let len_cm = list.len(items_cm);
    if (pos_cm >= len_cm) {
        return acc_cm;
    }
    let item_cm = list.get(items_cm, pos_cm);
    let new_acc_cm = acc_cm;
    if (map.has(item_cm, field_cm)) {
        let fv_cm = map.get(item_cm, field_cm);
        if (fv_cm == value_cm) {
            new_acc_cm = acc_cm + 1;
        }
    }
    return count_matching(items_cm, field_cm, value_cm, pos_cm + 1, new_acc_cm);
}

fn find_in_list_by_field(items_fif, field_fif, value_fif, pos_fif) {
    let len_fif = list.len(items_fif);
    if (pos_fif >= len_fif) {
        return -1;
    }
    let item_fif = list.get(items_fif, pos_fif);
    if (map.has(item_fif, field_fif)) {
        let fv_fif = map.get(item_fif, field_fif);
        if (fv_fif == value_fif) {
            return pos_fif;
        }
    }
    return find_in_list_by_field(items_fif, field_fif, value_fif, pos_fif + 1);
}

// ============================================================
// Level 2: Core Entity Constructors & Converters
