fn make_item(id_mi, sku_mi, name_mi, desc_mi, cat_id_mi, price_mi, qty_mi, min_qty_mi, supp_id_mi) {
    let item_mi = map.new();
    map.set(item_mi, "id", id_mi);
    map.set(item_mi, "sku", sku_mi);
    map.set(item_mi, "name", name_mi);
    map.set(item_mi, "description", desc_mi);
    map.set(item_mi, "category_id", cat_id_mi);
    map.set(item_mi, "unit_price", price_mi);
    map.set(item_mi, "quantity", qty_mi);
    map.set(item_mi, "min_quantity", min_qty_mi);
    map.set(item_mi, "supplier_id", supp_id_mi);
    return item_mi;
}

fn make_category(id_mc, name_mc, desc_mc) {
    let cat_mc = map.new();
    map.set(cat_mc, "id", id_mc);
    map.set(cat_mc, "name", name_mc);
    map.set(cat_mc, "description", desc_mc);
    return cat_mc;
}

fn make_supplier(id_ms, name_ms, contact_ms, email_ms, phone_ms) {
    let supp_ms = map.new();
    map.set(supp_ms, "id", id_ms);
    map.set(supp_ms, "name", name_ms);
    map.set(supp_ms, "contact", contact_ms);
    map.set(supp_ms, "email", email_ms);
    map.set(supp_ms, "phone", phone_ms);
    return supp_ms;
}

fn make_transaction(id_mt, item_id_mt, type_mt, qty_mt, date_mt, note_mt) {
    let txn_mt = map.new();
    map.set(txn_mt, "id", id_mt);
    map.set(txn_mt, "item_id", item_id_mt);
    map.set(txn_mt, "type", type_mt);
    map.set(txn_mt, "quantity", qty_mt);
    map.set(txn_mt, "date", date_mt);
    map.set(txn_mt, "note", note_mt);
    return txn_mt;
}

