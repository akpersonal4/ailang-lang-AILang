// ============================================================
// Level 3: Inventory Operations
// ============================================================
fn find_item_index(items_fii, item_id_fii, pos_fii) {
    let len_fii = list.len(items_fii);
    if (pos_fii >= len_fii) {
        return -1;
    }
    let item_fii = list.get(items_fii, pos_fii);
    if (map.has(item_fii, "id")) {
        if (map.get(item_fii, "id") == item_id_fii) {
            return pos_fii;
        }
    }
    return find_item_index(items_fii, item_id_fii, pos_fii + 1);
}

fn add_item_to_inventory(inv_ai, item_ai) {
    if (!map.has(inv_ai, "items")) {
        map.set(inv_ai, "items", list.new());
    }
    let items_ai = map.get(inv_ai, "items");
    list.append(items_ai, item_ai);
    return 0;
}

fn remove_item_from_inventory(inv_ri, item_id_ri) {
    if (!map.has(inv_ri, "items")) {
        return 0;
    }
    let items_ri = map.get(inv_ri, "items");
    let idx_ri = find_item_index(items_ri, item_id_ri, 0);
    if (idx_ri >= 0) {
        let item_ri = list.get(items_ri, idx_ri);
        if (map.has(item_ri, "sku")) {
            list.remove(items_ri, item_ri);
        }
    }
    return 0;
}

fn get_item_from_inventory(inv_gi, item_id_gi) {
    if (!map.has(inv_gi, "items")) {
        return map.new();
    }
    let items_gi = map.get(inv_gi, "items");
    let idx_gi = find_item_index(items_gi, item_id_gi, 0);
    if (idx_gi < 0) {
        return map.new();
    }
    let len_gi = list.len(items_gi);
    if (idx_gi < len_gi) {
        return list.get(items_gi, idx_gi);
    }
    return map.new();
}

fn update_item_stock(inv_us, item_id_us, delta_us) {
    if (!map.has(inv_us, "items")) {
        return 0;
    }
    let items_us = map.get(inv_us, "items");
    let idx_us = find_item_index(items_us, item_id_us, 0);
    if (idx_us < 0) {
        return 0;
    }
    let len_us = list.len(items_us);
    if (idx_us >= len_us) {
        return 0;
    }
    let item_us = list.get(items_us, idx_us);
    let cur_qty_us = 0;
    if (map.has(item_us, "quantity")) {
        cur_qty_us = map.get(item_us, "quantity");
    }
    map.set(item_us, "quantity", cur_qty_us + delta_us);
    return 0;
}

fn record_transaction(inv_rt, txn_rt) {
    if (!map.has(inv_rt, "transactions")) {
        map.set(inv_rt, "transactions", list.new());
    }
    let txns_rt = map.get(inv_rt, "transactions");
    list.append(txns_rt, txn_rt);
    return 0;
}

fn get_item_transactions_helper(inv_gth, item_id_gth, pos_gth, result_gth) {
    if (!map.has(inv_gth, "transactions")) {
        return result_gth;
    }
    let txns_gth = map.get(inv_gth, "transactions");
    let len_gth = list.len(txns_gth);
    if (pos_gth >= len_gth) {
        return result_gth;
    }
    let txn_gth = list.get(txns_gth, pos_gth);
    if (map.has(txn_gth, "item_id")) {
        if (map.get(txn_gth, "item_id") == item_id_gth) {
            list.append(result_gth, txn_gth);
        }
    }
    return get_item_transactions_helper(inv_gth, item_id_gth, pos_gth + 1, result_gth);
}

fn get_item_transactions(inv_git, item_id_git) {
    return get_item_transactions_helper(inv_git, item_id_git, 0, list.new());
}

fn get_low_stock_items_helper(inv_lsh, pos_lsh, result_lsh) {
    if (!map.has(inv_lsh, "items")) {
        return result_lsh;
    }
    let items_lsh = map.get(inv_lsh, "items");
    let len_lsh = list.len(items_lsh);
    if (pos_lsh >= len_lsh) {
        return result_lsh;
    }
    let item_lsh = list.get(items_lsh, pos_lsh);
    let qty_lsh = 999999;
    let min_qty_lsh = 0;
    if (map.has(item_lsh, "quantity")) {
        qty_lsh = map.get(item_lsh, "quantity");
    }
    if (map.has(item_lsh, "min_quantity")) {
        min_qty_lsh = map.get(item_lsh, "min_quantity");
    }
    if (qty_lsh < min_qty_lsh) {
        list.append(result_lsh, item_lsh);
    }
    return get_low_stock_items_helper(inv_lsh, pos_lsh + 1, result_lsh);
}

fn get_low_stock_items(inv_lsi) {
    return get_low_stock_items_helper(inv_lsi, 0, list.new());
}

fn get_category_items_helper(inv_gch, cat_id_gch, pos_gch, result_gch) {
