import list;
import map;
import string;
import convert;
import helpers;
import storage;
import stock_aging;

fn test_stock_aging_record_and_get_batches() {
    let tsagNow = helpers.helpers_unix_timestamp();
    let tsagRecord = stock_aging.stock_aging_record("SAG-PROD-001", "SAG-WH-001", 50, tsagNow);
    if (tsagRecord == false) {
        print("FAIL: stock_aging_record returned false");
        return false;
    }
    let tsagBatches = stock_aging.stock_aging_get_batches("SAG-PROD-001", "SAG-WH-001");
    if (tsagBatches == false) {
        print("FAIL: stock_aging_get_batches returned false");
        return false;
    }
    let tsagLen = list.len(tsagBatches);
    if (tsagLen == 0) {
        print("FAIL: stock_aging_get_batches - no batches found");
        return false;
    }
    let tsagFirst = list.get(tsagBatches, 0);
    let tsagProdId = helpers.helpers_get_map_value_safe(tsagFirst, "product_id", "");
    if (tsagProdId != "SAG-PROD-001") {
        print("FAIL: stock_aging_get_batches - wrong product_id");
        return false;
    }
    print("PASS: stock_aging_record and get_batches");
    return true;
}

fn test_stock_aging_summary() {
    let tsasNow = helpers.helpers_unix_timestamp();
    stock_aging.stock_aging_record("SAG-PROD-002", "SAG-WH-001", 100, tsasNow);
    let tsasOld = tsasNow - 7000000;
    stock_aging.stock_aging_record("SAG-PROD-002", "SAG-WH-001", 50, tsasOld);
    let tsasSummary = stock_aging.stock_aging_summary("SAG-PROD-002");
    if (tsasSummary == false) {
        print("FAIL: stock_aging_summary returned false");
        return false;
    }
    let tsas0_30 = helpers.helpers_get_map_value_safe(tsasSummary, "0_30_days", -1);
    if (tsas0_30 <= 0) {
        print("FAIL: stock_aging_summary - expected positive 0_30_days");
        return false;
    }
    let tsas61_90 = helpers.helpers_get_map_value_safe(tsasSummary, "61_90_days", -1);
    if (tsas61_90 <= 0) {
        print("FAIL: stock_aging_summary - expected positive 61_90_days for old batch (7000000s = ~81 days)");
        return false;
    }
    print("PASS: stock_aging_summary");
    return true;
}

fn test_stock_aging_remove_batch() {
    let tsarNow = helpers.helpers_unix_timestamp();
    let tsarRecord = stock_aging.stock_aging_record("SAG-PROD-003", "SAG-WH-001", 25, tsarNow);
    let tsarBatchId = helpers.helpers_get_map_value_safe(tsarRecord, "id", "");
    let tsarBefore = stock_aging.stock_aging_get_batches("SAG-PROD-003", "SAG-WH-001");
    let tsarBeforeLen = list.len(tsarBefore);
    let tsarRemove = stock_aging.stock_aging_remove_batch("SAG-PROD-003", "SAG-WH-001", tsarBatchId);
    if (tsarRemove == false) {
        print("FAIL: stock_aging_remove_batch returned false");
        return false;
    }
    let tsarAfter = stock_aging.stock_aging_get_batches("SAG-PROD-003", "SAG-WH-001");
    let tsarAfterLen = list.len(tsarAfter);
    if (tsarAfterLen >= tsarBeforeLen) {
        print("FAIL: stock_aging_remove_batch - count did not decrease");
        return false;
    }
    print("PASS: stock_aging_remove_batch");
    return true;
}

fn main() {
    let tsa1 = test_stock_aging_record_and_get_batches();
    if (tsa1 == false) {
        return 1;
    }
    let tsa2 = test_stock_aging_summary();
    if (tsa2 == false) {
        return 1;
    }
    let tsa3 = test_stock_aging_remove_batch();
    if (tsa3 == false) {
        return 1;
    }
    print("ALL STOCK AGING TESTS PASSED");
    return 0;
}
