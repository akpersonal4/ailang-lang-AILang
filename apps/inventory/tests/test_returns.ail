import list;
import map;
import string;
import convert;
import helpers;
import storage;
import returns;

fn test_returns_create() {
    let trcResult = returns.returns_create("SO-TEST-001", "PRD-TEST-001", 2, "Damaged in transit", "John Doe");
    if (trcResult == false) {
        print("FAIL: returns_create returned false");
        return false;
    }
    let trcId = helpers.helpers_get_map_value_safe(trcResult, "id", "");
    if (trcId == "") {
        print("FAIL: returns_create - no id generated");
        return false;
    }
    let trcStatus = helpers.helpers_get_map_value_safe(trcResult, "status", "");
    if (trcStatus != "pending") {
        print("FAIL: returns_create - expected status pending, got " + trcStatus);
        return false;
    }
    let trcQty = helpers.helpers_get_map_value_safe(trcResult, "quantity", 0);
    if (trcQty != 2) {
        print("FAIL: returns_create - expected quantity 2, got " + convert.to_string(trcQty));
        return false;
    }
    let trcOrderId = helpers.helpers_get_map_value_safe(trcResult, "order_id", "");
    if (trcOrderId != "SO-TEST-001") {
        print("FAIL: returns_create - order_id mismatch");
        return false;
    }
    print("PASS: returns_create");
    return true;
}

fn test_returns_get_by_id_missing() {
    let trgmResult = returns.returns_get_by_id("NONEXISTENT-RETURN-ID");
    if (trgmResult != false) {
        print("FAIL: returns_get_by_id_missing - expected false");
        return false;
    }
    print("PASS: returns_get_by_id_missing");
    return true;
}

fn test_returns_approve() {
    let traCreated = returns.returns_create("SO-TEST-002", "PRD-TEST-002", 1, "Wrong item", "Jane Doe");
    let traId = helpers.helpers_get_map_value_safe(traCreated, "id", "");
    let traUpdated = returns.returns_approve(traId);
    if (traUpdated == false) {
        print("FAIL: returns_approve returned false");
        return false;
    }
    let traFetched = returns.returns_get_by_id(traId);
    let traStatus = helpers.helpers_get_map_value_safe(traFetched, "status", "");
    if (traStatus != "approved") {
        print("FAIL: returns_approve - expected status approved, got " + traStatus);
        return false;
    }
    print("PASS: returns_approve");
    return true;
}

fn test_returns_reject() {
    let trrCreated = returns.returns_create("SO-TEST-003", "PRD-TEST-003", 3, "Defective", "Bob Smith");
    let trrId = helpers.helpers_get_map_value_safe(trrCreated, "id", "");
    let trrUpdated = returns.returns_reject(trrId, "Return window expired");
    if (trrUpdated == false) {
        print("FAIL: returns_reject returned false");
        return false;
    }
    let trrFetched = returns.returns_get_by_id(trrId);
    let trrStatus = helpers.helpers_get_map_value_safe(trrFetched, "status", "");
    if (trrStatus != "rejected") {
        print("FAIL: returns_reject - expected status rejected, got " + trrStatus);
        return false;
    }
    let trrReason = helpers.helpers_get_map_value_safe(trrFetched, "rejection_reason", "");
    if (trrReason != "Return window expired") {
        print("FAIL: returns_reject - rejection reason mismatch");
        return false;
    }
    print("PASS: returns_reject");
    return true;
}

fn test_returns_list_by_order() {
    let trlo1 = returns.returns_create("SO-LIST", "PRD-LIST-1", 1, "Test reason 1", "User A");
    let trlo2 = returns.returns_create("SO-LIST", "PRD-LIST-2", 2, "Test reason 2", "User B");
    let trloOrderResults = returns.returns_list_by_order("SO-LIST");
    let trloLen = list.len(trloOrderResults);
    if (trloLen < 2) {
        print("FAIL: returns_list_by_order - expected at least 2, got " + convert.to_string(trloLen));
        return false;
    }
    print("PASS: returns_list_by_order (" + convert.to_string(trloLen) + " items)");
    return true;
}

fn test_returns_complete() {
    let trcmpCreated = returns.returns_create("SO-TEST-004", "PRD-TEST-004", 1, "Change of mind", "Alice W");
    let trcmpId = helpers.helpers_get_map_value_safe(trcmpCreated, "id", "");
    returns.returns_approve(trcmpId);
    let trcmpUpdated = returns.returns_complete(trcmpId);
    if (trcmpUpdated == false) {
        print("FAIL: returns_complete returned false");
        return false;
    }
    let trcmpFetched = returns.returns_get_by_id(trcmpId);
    let trcmpStatus = helpers.helpers_get_map_value_safe(trcmpFetched, "status", "");
    if (trcmpStatus != "completed") {
        print("FAIL: returns_complete - expected status completed, got " + trcmpStatus);
        return false;
    }
    print("PASS: returns_complete");
    return true;
}

fn main() {
    let tr1 = test_returns_create();
    if (tr1 == false) {
        return 1;
    }
    let tr2 = test_returns_get_by_id_missing();
    if (tr2 == false) {
        return 1;
    }
    let tr3 = test_returns_approve();
    if (tr3 == false) {
        return 1;
    }
    let tr4 = test_returns_reject();
    if (tr4 == false) {
        return 1;
    }
    let tr5 = test_returns_list_by_order();
    if (tr5 == false) {
        return 1;
    }
    let tr6 = test_returns_complete();
    if (tr6 == false) {
        return 1;
    }
    print("ALL RETURNS TESTS PASSED");
    return 0;
}
