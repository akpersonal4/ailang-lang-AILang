import list;
import map;
import string;
import convert;
import helpers;
import storage;
import notification;
import search;

fn tn_create_product() {
    let tnpProduct = map.new();
    map.set(tnpProduct, "id", "TNOT-PRD-001");
    map.set(tnpProduct, "name", "Test Notification Product");
    map.set(tnpProduct, "sku", "NOT-001");
    map.set(tnpProduct, "category_id", "");
    map.set(tnpProduct, "unit_price", 30);
    map.set(tnpProduct, "cost_price", 15);
    map.set(tnpProduct, "unit", "pcs");
    map.set(tnpProduct, "active", true);
    let tnpNow = helpers.helpers_current_timestamp();
    map.set(tnpProduct, "created_at", tnpNow);
    map.set(tnpProduct, "updated_at", "");
    storage.storage_add("products", tnpProduct);
    let tnpLoaded = helpers.helpers_find_in_list(storage.storage_list("products"), "id", "TNOT-PRD-001");
    if (tnpLoaded == false) {
        return false;
    }
    return true;
}

