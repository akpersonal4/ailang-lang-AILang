import list;
import map;
import string;
import convert;
import helpers;
import storage;
import price_history;

fn test_price_history_record() {
    let tpResult = price_history.price_history_record("PROD-PH-001", 100, 120, "admin");
    if (tpResult == false) {
        print("FAIL: price_history_record returned false");
        return false;
    }
    let tpId = helpers.helpers_get_map_value_safe(tpResult, "id", "");
    if (tpId == "") {
        print("FAIL: price_history_record - no id");
        return false;
    }
    let tpProductId = helpers.helpers_get_map_value_safe(tpResult, "product_id", "");
    if (tpProductId != "PROD-PH-001") {
        print("FAIL: price_history_record - product_id mismatch");
        return false;
    }
    let tpOldPrice = helpers.helpers_get_map_value_safe(tpResult, "old_price", 0);
    if (tpOldPrice != 100) {
        print("FAIL: price_history_record - old_price mismatch");
        return false;
    }
    let tpNewPrice = helpers.helpers_get_map_value_safe(tpResult, "new_price", 0);
    if (tpNewPrice != 120) {
        print("FAIL: price_history_record - new_price mismatch");
        return false;
    }
    print("PASS: price_history_record");
    return true;
}

fn test_price_history_get_by_product() {
    price_history.price_history_record("PROD-PH-002", 200, 220, "editor");
    price_history.price_history_record("PROD-PH-002", 220, 250, "editor");
    price_history.price_history_record("PROD-PH-003", 50, 60, "viewer");
    let tpResults = price_history.price_history_get_by_product("PROD-PH-002");
    if (tpResults == false) {
        print("FAIL: price_history_get_by_product returned false");
        return false;
    }
    let tpLen = list.len(tpResults);
    if (tpLen != 2) {
        print("FAIL: price_history_get_by_product - expected 2, got " + convert.to_string(tpLen));
        return false;
    }
    print("PASS: price_history_get_by_product (" + convert.to_string(tpLen) + " items)");
    return true;
}

fn test_price_history_latest() {
    price_history.price_history_record("PROD-PH-004", 300, 350, "manager");
    price_history.price_history_record("PROD-PH-004", 350, 400, "manager");
    let tpLatest = price_history.price_history_latest("PROD-PH-004");
    if (tpLatest == false) {
        print("FAIL: price_history_latest returned false");
        return false;
    }
    let tpNewPrice = helpers.helpers_get_map_value_safe(tpLatest, "new_price", 0);
    if (tpNewPrice != 400) {
        print("FAIL: price_history_latest - expected new_price 400, got " + convert.to_string(tpNewPrice));
        return false;
    }
    print("PASS: price_history_latest");
    return true;
}

fn test_price_history_latest_empty() {
    let tpLatest = price_history.price_history_latest("PROD-PH-NONEXISTENT");
    if (tpLatest != false) {
        print("FAIL: price_history_latest_empty - expected false");
        return false;
    }
    print("PASS: price_history_latest_empty");
    return true;
}

fn test_price_history_list() {
    let tpResults = price_history.price_history_list();
    if (tpResults == false) {
        print("FAIL: price_history_list returned false");
        return false;
    }
    let tpLen = list.len(tpResults);
    if (tpLen == 0) {
        print("FAIL: price_history_list - empty list");
        return false;
    }
    print("PASS: price_history_list (" + convert.to_string(tpLen) + " items)");
    return true;
}

fn main() {
    let tpr1 = test_price_history_record();
    if (tpr1 == false) {
        return 1;
    }
    let tpr2 = test_price_history_get_by_product();
    if (tpr2 == false) {
        return 1;
    }
    let tpr3 = test_price_history_latest();
    if (tpr3 == false) {
        return 1;
    }
    let tpr4 = test_price_history_latest_empty();
    if (tpr4 == false) {
        return 1;
    }
    let tpr5 = test_price_history_list();
    if (tpr5 == false) {
        return 1;
    }
    print("ALL PRICE HISTORY TESTS PASSED");
    return 0;
}
