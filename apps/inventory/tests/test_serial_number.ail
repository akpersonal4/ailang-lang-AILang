import list;
import map;
import string;
import convert;
import helpers;
import storage;
import serial_number;

fn test_serial_register() {
    let tsrResult = serial_number.serial_register("PRD-SR-001", "SN-100001", "BAT-SR-001");
    if (tsrResult == false) {
        print("FAIL: serial_register returned false");
        return false;
    }
    let tsrId = helpers.helpers_get_map_value_safe(tsrResult, "id", "");
    if (tsrId == "") {
        print("FAIL: serial_register - serial id missing");
        return false;
    }
    let tsrStatus = helpers.helpers_get_map_value_safe(tsrResult, "status", "");
    if (tsrStatus != "available") {
        print("FAIL: serial_register - expected status available, got " + tsrStatus);
        return false;
    }
    let tsrSerialNum = helpers.helpers_get_map_value_safe(tsrResult, "serial_number", "");
    if (tsrSerialNum != "SN-100001") {
        print("FAIL: serial_register - expected SN-100001, got " + tsrSerialNum);
        return false;
    }
    print("PASS: serial_register");
    return true;
}

fn test_serial_get_by_id_missing() {
    let tsgmResult = serial_number.serial_get_by_id("NONEXISTENT-SERIAL-ID");
    if (tsgmResult != false) {
        print("FAIL: serial_get_by_id_missing - expected false");
        return false;
    }
    print("PASS: serial_get_by_id_missing");
    return true;
}

fn test_serial_find_by_serial() {
    let tsfbsReg = serial_number.serial_register("PRD-FIND-001", "SN-FIND-001", "BAT-FIND-001");
    let tsfbsFound = serial_number.serial_find_by_serial("PRD-FIND-001", "SN-FIND-001");
    if (tsfbsFound == false) {
        print("FAIL: serial_find_by_serial returned false");
        return false;
    }
    let tsfbsSerialNum = helpers.helpers_get_map_value_safe(tsfbsFound, "serial_number", "");
    if (tsfbsSerialNum != "SN-FIND-001") {
        print("FAIL: serial_find_by_serial - expected SN-FIND-001, got " + tsfbsSerialNum);
        return false;
    }
    print("PASS: serial_find_by_serial");
    return true;
}

fn test_serial_list_by_product() {
    let tslbp1 = serial_number.serial_register("PRD-LIST-002", "SN-LIST-001", "BAT-LIST-001");
    let tslbp2 = serial_number.serial_register("PRD-LIST-002", "SN-LIST-002", "BAT-LIST-001");
    let tslbpResults = serial_number.serial_list_by_product("PRD-LIST-002");
    let tslbpLen = list.len(tslbpResults);
    if (tslbpLen < 2) {
        print("FAIL: serial_list_by_product - expected at least 2, got " + convert.to_string(tslbpLen));
        return false;
    }
    print("PASS: serial_list_by_product (" + convert.to_string(tslbpLen) + " items)");
    return true;
}

fn test_serial_update_status() {
    let tsusReg = serial_number.serial_register("PRD-UPD-002", "SN-UPD-001", "BAT-UPD-001");
    let tsusId = helpers.helpers_get_map_value_safe(tsusReg, "id", "");
    let tsusResult = serial_number.serial_update_status(tsusId, "sold");
    if (tsusResult == false) {
        print("FAIL: serial_update_status returned false");
        return false;
    }
    let tsusUpdated = serial_number.serial_get_by_id(tsusId);
    if (tsusUpdated == false) {
        print("FAIL: serial_update_status - not found after update");
        return false;
    }
    let tsusNewStatus = helpers.helpers_get_map_value_safe(tsusUpdated, "status", "");
    if (tsusNewStatus != "sold") {
        print("FAIL: serial_update_status - expected sold, got " + tsusNewStatus);
        return false;
    }
    print("PASS: serial_update_status");
    return true;
}

fn test_serial_list_available() {
    let tslaAvail = serial_number.serial_register("PRD-AVAIL-001", "SN-AVAIL-001", "BAT-AVAIL-001");
    let tslaSold = serial_number.serial_register("PRD-AVAIL-001", "SN-AVAIL-002", "BAT-AVAIL-001");
    let tslaSoldId = helpers.helpers_get_map_value_safe(tslaSold, "id", "");
    serial_number.serial_update_status(tslaSoldId, "sold");
    let tslaResults = serial_number.serial_list_available("PRD-AVAIL-001");
    let tslaLen = list.len(tslaResults);
    if (tslaLen == 0) {
        print("FAIL: serial_list_available - expected at least 1 available");
        return false;
    }
    let tslaFirst = list.get(tslaResults, 0);
    let tslaFirstStatus = helpers.helpers_get_map_value_safe(tslaFirst, "status", "");
    if (tslaFirstStatus != "available") {
        print("FAIL: serial_list_available - found non-available serial");
        return false;
    }
    print("PASS: serial_list_available (" + convert.to_string(tslaLen) + " available)");
    return true;
}

fn main() {
    let ts1 = test_serial_register();
    if (ts1 == false) {
        return 1;
    }
    let ts2 = test_serial_get_by_id_missing();
    if (ts2 == false) {
        return 1;
    }
    let ts3 = test_serial_find_by_serial();
    if (ts3 == false) {
        return 1;
    }
    let ts4 = test_serial_list_by_product();
    if (ts4 == false) {
        return 1;
    }
    let ts5 = test_serial_update_status();
    if (ts5 == false) {
        return 1;
    }
    let ts6 = test_serial_list_available();
    if (ts6 == false) {
        return 1;
    }
    print("ALL SERIAL NUMBER TESTS PASSED");
    return 0;
}
