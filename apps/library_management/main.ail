// ============================================================
// Additional Book Operations
// ============================================================

fn delete_book(books, book_id) {
    let book_idx = find_book_by_id(books, book_id);
    if (book_idx == -1) { return false }
    let book = list.get(books, book_idx);
    list.remove(books, book);
    return true
}

fn get_member_books_list(member) {
    return map.get(member, "books_issued")
}

fn get_book_by_index(books, index) {
    return list.get(books, index)
}

fn get_member_by_index(members, index) {
    return list.get(members, index)
}

fn category_exists_helper(categories, j, category) {
    if (j >= list.len(categories)) { return false }
    if (string.equals(list.get(categories, j), category)) { return true }
    return category_exists_helper(categories, j + 1, category)
}

fn category_exists(categories, category) {
    return category_exists_helper(categories, 0, category)
}

fn get_all_categories_helper(books, i, categories) {
    if (i >= list.len(books)) { return categories }
    let book = list.get(books, i);
    let category = map.get(book, "category");
    // Check if category already exists in the list
    if (!category_exists(categories, category)) {
        list.append(categories, category)
    }
    return get_all_categories_helper(books, i + 1, categories)
}

fn get_all_categories(books) {
    let categories = list.new();
    return get_all_categories_helper(books, 0, categories)
}

// ============================================================
// Extended Demo Functions
// ============================================================

fn demonstrate_multiple_issues(books, members) {
    print("\n--- Demonstrating Multiple Issues ---");
    let result1 = issue_book(books, members, 2, 1, "2024-01-15");
    print("Issue Book 2 to Member 1:", result1);
    let result2 = issue_book(books, members, 3, 1, "2024-01-15");
    print("Issue Book 3 to Member 1:", result2);
    let result3 = issue_book(books, members, 1, 2, "2024-01-15");
    print("Issue Book 1 to Member 2:", result3);
    return true
}

fn demonstrate_search_operations(books, members) {
    print("\n--- Demonstrating Search Operations ---");
    
    let fiction_books = search_books_by_category(books, "Fiction");
    print("Found", list.len(fiction_books), "Fiction books.");
    
    let author_books = search_books_by_author(books, "Martin");
    print("Found", list.len(author_books), "books by Martin.");
    
    let title_books = search_books_by_title(books, "Algorithms");
    print("Found", list.len(title_books), "books with 'Algorithms' in title.");
    
    let member_search = search_members_by_name(members, "Alice");
    print("Found", list.len(member_search), "member(s) named Alice.");
    
    let email_search = search_members_by_email(members, "bob");
    print("Found", list.len(email_search), "member(s) with 'bob' in email.");
    
    return true
}

fn demonstrate_fine_operations(members) {
    print("\n--- Demonstrating Fine Operations ---");
    add_fine_to_member(members, 1, 25);
    print("Added $25 fine to Member 1.");
    add_fine_to_member(members, 2, 10);
    print("Added $10 fine to Member 2.");
    add_fine_to_member(members, 1, 15);
    print("Added $15 fine to Member 1 (total: $40).");
    
    let book_count = count_total_fines(members);
    print("Total fines across all members:", book_count);
    
    return true
}

fn demonstrate_update_operations(books, members) {
    print("\n--- Demonstrating Update Operations ---");
    let book_idx = find_book_by_id(books, 1);
    if (book_idx != -1) {
        let book = list.get(books, book_idx);
        update_book_title(book, "The Great Gatsby (Updated Edition)");
        print("Updated Book 1 title.");
    }
    
    let member_idx = find_member_by_id(members, 1);
    if (member_idx != -1) {
        let member = list.get(members, member_idx);
        update_member_email(member, "alice.johnson@newdomain.com");
        print("Updated Member 1 email.");
    }
    
    return true
}

fn print_separator() {
    print("-----------------------------------------------");
    return true
}

// ============================================================
// Additional Validation and Utility Functions
// ============================================================

fn validate_isbn(books, isbn) {
    if (find_book_by_isbn(books, isbn) != -1) { return false }
    return true
}

fn get_book_field(book, field) {
    return map.get(book, field)
}

fn get_member_field(member, field) {
    return map.get(member, field)
}

fn get_issued_to_list(book) {
    return map.get(book, "issued_to")
}

fn get_issued_to_count(book) {
    return list.len(map.get(book, "issued_to"))
}

fn calculate_utilization_rate(books) {
    let total = get_total_copies(books);
    let available = count_total_books(books);
    if (total == 0) { return 0 }
    return (total - available) * 100 / total
}

// ============================================================
// Error Messages Constants
// ============================================================

fn error_book_not_found() {
    return "Error: Book not found in the library database."
}

fn error_member_not_found() {
    return "Error: Member not found in the database."
}

fn error_book_not_available() {
    return "Error: The requested book is not available for checkout."
}

fn error_member_cannot_borrow() {
    return "Error: Member cannot borrow more books at this time."
}

fn error_member_has_not_borrowed() {
    return "Error: Member does not have this book checked out."
}

