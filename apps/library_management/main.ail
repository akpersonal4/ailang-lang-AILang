fn initialize_sample_data() {
    let books = list.new();
    
    // Add sample books
    books = add_book(books, 1, "The Great Gatsby", "F. Scott Fitzgerald", "9780743273565", "Fiction", 3);
    books = add_book(books, 2, "To Kill a Mockingbird", "Harper Lee", "9780061120081", "Fiction", 2);
    books = add_book(books, 3, "1984", "George Orwell", "9780451528935", "Dystopian", 4);
    books = add_book(books, 4, "Pride and Prejudice", "Jane Austen", "9780141435147", "Romance", 2);
    books = add_book(books, 5, "The Catcher in the Rye", "J.D. Salinger", "9780316769488", "Fiction", 3);
    books = add_book(books, 6, "Clean Code", "Robert Martin", "9780132350884", "Programming", 5);
    books = add_book(books, 7, "The Pragmatic Programmer", "Andy Hunt", "9780201616224", "Programming", 4);
    books = add_book(books, 8, "Introduction to Algorithms", "Cormen et al", "9780262033848", "Computer Science", 2);
    
    return books
}

fn main() {
    print("=== Library Management System ===");
    print("Initializing...");
    
    let books = list.new();
    let members = list.new();
    
    // Initialize with sample data
    books = initialize_sample_data();
    members = add_member(members, 1, "Alice Johnson", "alice@example.com", "555-0101", "123 Main St");
    members = add_member(members, 2, "Bob Smith", "bob@example.com", "555-0102", "456 Oak Ave");
    members = add_member(members, 3, "Carol White", "carol@example.com", "555-0103", "789 Pine Rd");
    members = add_member(members, 4, "David Brown", "david@example.com", "555-0104", "321 Elm St");
    members = add_member(members, 5, "Eve Davis", "eve@example.com", "555-0105", "654 Maple Dr");
    
    print("Library initialized with sample data.");
    print_separator();
    
    // Print statistics
    print_statistics(books, members);
    
    // Print all books
    print("\n=== Book Catalog ===");
    print_books(books);
    print_separator();
    
    // Print all members
    print("\n=== Member Database ===");
    print_members(members);
    print_separator();
    
    // Demonstrate search functionality
    demonstrate_search_operations(books, members);
    print_separator();
    
    // Demonstrate issue functionality
    demonstrate_multiple_issues(books, members);
    print("\n--- After Multiple Issues ---");
    print_statistics(books, members);
    
    // Demonstrate fine operations
    demonstrate_fine_operations(members);
    print_separator();
    
    // Demonstrate update operations
    demonstrate_update_operations(books, members);
    print("\n--- After Updates ---");
    print_books(books);
    
    // Generate reports
    print("\n=== Generating Reports ===");
    generate_book_report(books, "book_report.csv");
    print("Book report saved to book_report.csv");
    generate_member_report(members, "member_report.csv");
    print("Member report saved to member_report.csv");
    print_separator();
    
    // Save data
    print("\n=== Saving Data ===");
    save_data(books, members, "books.json", "members.json");
    print("Data saved to books.json and members.json");
    
    // Extended statistics
    print("\n=== Extended Statistics ===");
    print_extended_statistics(books, members);
    
    // All categories
    print("\n=== Book Categories ===");
    let categories = get_all_categories(books);
    print("Total categories:", list.len(categories));
    
    print("\n=== Demo Complete ===");
    return 0
}
