fn c_to_f(c) { return c * 9 / 5 + 32 }
fn f_to_c(f) { return (f - 32) * 5 / 9 }
fn c_to_k(c) { return c + 273 }
fn f_to_k(f) { return (f - 32) * 5 / 9 + 273 }

fn main() {
    print("=== Temperature Converter ===");
    print("0 C to F:", c_to_f(0));
    print("100 C to F:", c_to_f(100));
    print("32 F to C:", f_to_c(32));
    print("212 F to C:", f_to_c(212));
    print("0 C to K:", c_to_k(0));
    print("100 C to K:", c_to_k(100));
    print("32 F to K:", f_to_k(32))
}
