import environment;
import storage;
import user;
import ticket;
import comment;
import audit_log;
import csv_ops;
import list;
import map;
import string;
import convert;
import file;
import path;
import json;

let SESSION_FILE = "data/session.json";

fn cv_print_comments_rec(cvComments, cvIdx) {
    if (cvIdx >= list.len(cvComments)) {
        return true;
    }
    let cvC = list.get(cvComments, cvIdx);
    print("[" + convert.to_string(map.get(cvC, "author_id")) + "] " + map.get(cvC, "content"));
    return cv_print_comments_rec(cvComments, cvIdx + 1);
}

fn cs_print_results_rec(csResults, csIdx) {
    if (csIdx >= list.len(csResults)) {
        return true;
    }
    let csT = list.get(csResults, csIdx);
    print("  [" + convert.to_string(map.get(csT, "id")) + "] " + map.get(csT, "title") + " (" + map.get(csT, "status") + ", " + map.get(csT, "priority") + ")");
    return cs_print_results_rec(csResults, csIdx + 1);
}

fn cf_print_results_rec(cfResults, cfIdx) {
    if (cfIdx >= list.len(cfResults)) {
        return true;
    }
    let cfT = list.get(cfResults, cfIdx);
    print("  [" + convert.to_string(map.get(cfT, "id")) + "] " + map.get(cfT, "title") + " (" + map.get(cfT, "status") + ")");
    return cf_print_results_rec(cfResults, cfIdx + 1);
}

fn cm_print_results_rec(cmResults, cmIdx) {
    if (cmIdx >= list.len(cmResults)) {
        return true;
    }
    let cmT = list.get(cmResults, cmIdx);
    print("  [" + convert.to_string(map.get(cmT, "id")) + "] " + map.get(cmT, "title") + " (" + map.get(cmT, "status") + ", " + map.get(cmT, "priority") + ")");
    return cm_print_results_rec(cmResults, cmIdx + 1);
}

fn cr_print_agent_rec(crTickets, crCounts, crIdx) {
    if (crIdx >= list.len(crTickets)) {
        return true;
    }
    let crT = list.get(crTickets, crIdx);
    let crAid = convert.to_string(map.get(crT, "assignee_id"));
    if (map.has(crCounts, crAid) == true) {
        print("  Agent " + crAid + ": " + convert.to_string(map.get(crCounts, crAid)));
    }
    return cr_print_agent_rec(crTickets, crCounts, crIdx + 1);
}

fn cr_count_daily_rec(crTickets, crNow, crSevenDays, crIdx, crCreatedCount, crResolvedCount) {
    if (crIdx >= list.len(crTickets)) {
        return crCreatedCount;
    }
    let crT = list.get(crTickets, crIdx);
    let crCreatedAt = map.get(crT, "created_at");
    if (crNow - crCreatedAt < crSevenDays) {
        return cr_count_daily_rec(crTickets, crNow, crSevenDays, crIdx + 1, crCreatedCount + 1, crResolvedCount);
    }
    return cr_count_daily_rec(crTickets, crNow, crSevenDays, crIdx + 1, crCreatedCount, crResolvedCount);
}

fn cl_print_users_rec(clUsers, clIdx) {
    if (clIdx >= list.len(clUsers)) {
        return true;
    }
    let clU = list.get(clUsers, clIdx);
    print("  [" + convert.to_string(map.get(clU, "id")) + "] " + map.get(clU, "username") + " (" + map.get(clU, "role") + ")");
    return cl_print_users_rec(clUsers, clIdx + 1);
}

fn session_load() {
    if (file.exists(SESSION_FILE) == false) {
        return map.new();
    }
    let scContent = file.read(SESSION_FILE);
    return json.parse(scContent);
}

fn session_save(scUserId, scUsername) {
    let scSession = map.new();
    map.set(scSession, "user_id", scUserId);
    map.set(scSession, "username", scUsername);
    let scJson = json.stringify(scSession);
    file.write(SESSION_FILE, scJson);
    return true;
}

fn session_clear() {
    if (file.exists(SESSION_FILE) == true) {
        file.remove(SESSION_FILE);
    }
    return true;
}

fn session_get_user_id() {
    let scSession = session_load();
    if (map.has(scSession, "user_id") == false) {
        return 0;
    }
    return map.get(scSession, "user_id");
}

fn session_require_login() {
    let scUserId = session_get_user_id();
    if (scUserId == 0) {
        print("Error: Not logged in. Use 'login <username> <password>' first.");
        return 0;
    }
    return scUserId;
}

fn session_require_role(scAction) {
    let scUserId = session_require_login();
    if (scUserId == 0) {
        return 0;
    }
    if (user.user_has_permission(scUserId, scAction) == false) {
        print("Error: Insufficient permissions for " + scAction);
        return 0;
    }
    return scUserId;
}

fn cmd_register(crArgs) {
    if (list.len(crArgs) < 4) {
        print("Usage: register <username> <email> <password>");
        return true;
    }
    let crUsername = list.get(crArgs, 1);
    let crEmail = list.get(crArgs, 2);
    let crPassword = list.get(crArgs, 3);
    let crUser = user.user_create(crUsername, crEmail, crPassword);
    if (map.has(crUser, "id") == false) {
        print("Error: Username or email already exists.");
        return true;
    }
    print("User registered: " + crUsername + " (ID: " + convert.to_string(map.get(crUser, "id")) + ")");
    return true;
}

fn cmd_login(cmArgs) {
    if (list.len(cmArgs) < 3) {
        print("Usage: login <username> <password>");
        return true;
    }
    let cmUsername = list.get(cmArgs, 1);
    let cmPassword = list.get(cmArgs, 2);
    let cmUser = user.user_authenticate(cmUsername, cmPassword);
    if (map.has(cmUser, "id") == false) {
        print("Error: Invalid username or password.");
        return true;
    }
    session_save(map.get(cmUser, "id"), cmUsername);
    print("Logged in as " + cmUsername + " (role: " + map.get(cmUser, "role") + ")");
    return true;
}

fn cmd_logout(coArgs) {
    let coUserId = session_require_login();
    if (coUserId == 0) {
        return true;
    }
    let coSession = session_load();
    let coUsername = map.get(coSession, "username");
    session_clear();
    print("Logged out " + coUsername);
    return true;
}

fn cmd_create_ticket(ctArgs) {
    let ctUserId = session_require_role("create_ticket");
    if (ctUserId == 0) {
        return true;
    }
    if (list.len(ctArgs) < 5) {
        print("Usage: create-ticket <title> <priority> <category> <description>");
        return true;
    }
    let ctTitle = list.get(ctArgs, 1);
    let ctPriority = list.get(ctArgs, 2);
    let ctCategory = list.get(ctArgs, 3);
    let ctDescription = list.get(ctArgs, 4);
    let ctTicket = ticket.ticket_create(ctTitle, ctPriority, ctCategory, ctDescription, ctUserId);
    audit_log.audit_log_add(map.get(ctTicket, "id"), ctUserId, "created", "", ctTitle);
    print("Ticket created: ID " + convert.to_string(map.get(ctTicket, "id")));
    return true;
}

fn cmd_update_ticket(cuArgs) {
    if (list.len(cuArgs) < 4) {
        print("Usage: update-ticket <id> <field> <value>");
        return true;
    }
    let cuTicketId = convert.to_int(list.get(cuArgs, 1));
    let cuField = list.get(cuArgs, 2);
    let cuValue = list.get(cuArgs, 3);
    let cuTicket = ticket.ticket_find_by_id(cuTicketId);
    if (map.has(cuTicket, "id") == false) {
        print("Error: Ticket not found.");
        return true;
    }
    let cuUserId = session_require_login();
    if (cuUserId == 0) {
        return true;
    }
    let cuHasAny = user.user_has_permission(cuUserId, "update_any_ticket");
    if (cuHasAny == false) {
        let cuHasOwn = user.user_has_permission_on_ticket(cuUserId, "update_own_ticket", cuTicket);
        if (cuHasOwn == false) {
            print("Error: Cannot update this ticket.");
            return true;
        }
    }
    let cuOldValue = map.get(cuTicket, cuField);
    ticket.ticket_update(cuTicketId, cuField, cuValue);
    audit_log.audit_log_add(cuTicketId, cuUserId, "updated", cuOldValue, cuValue);
    print("Ticket " + convert.to_string(cuTicketId) + " updated: " + cuField + " = " + cuValue);
    return true;
}

fn cmd_assign_ticket(caArgs) {
    let caUserId = session_require_role("assign_ticket");
    if (caUserId == 0) {
        return true;
    }
    if (list.len(caArgs) < 3) {
        print("Usage: assign-ticket <id> <username>");
        return true;
    }
    let caTicketId = convert.to_int(list.get(caArgs, 1));
    let caAssigneeName = list.get(caArgs, 2);
    let caAssignee = user.user_find_by_username(caAssigneeName);
    if (map.has(caAssignee, "id") == false) {
        print("Error: User not found.");
        return true;
    }
    let caTicket = ticket.ticket_find_by_id(caTicketId);
    if (map.has(caTicket, "id") == false) {
        print("Error: Ticket not found.");
        return true;
    }
    let caOldAssignee = map.get(caTicket, "assignee_id");
    ticket.ticket_assign(caTicketId, map.get(caAssignee, "id"));
    audit_log.audit_log_add(caTicketId, caUserId, "assigned", convert.to_string(caOldAssignee), caAssigneeName);
    print("Ticket " + convert.to_string(caTicketId) + " assigned to " + caAssigneeName);
    return true;
}

fn cmd_resolve_ticket(crArgs) {
    let crUserId = session_require_role("resolve_ticket");
    if (crUserId == 0) {
        return true;
    }
    if (list.len(crArgs) < 2) {
        print("Usage: resolve-ticket <id>");
        return true;
    }
    let crTicketId = convert.to_int(list.get(crArgs, 1));
    let crTicket = ticket.ticket_find_by_id(crTicketId);
    if (map.has(crTicket, "id") == false) {
        print("Error: Ticket not found.");
        return true;
    }
    let crOldStatus = map.get(crTicket, "status");
    ticket.ticket_set_status(crTicketId, "resolved");
    audit_log.audit_log_add(crTicketId, crUserId, "status_changed", crOldStatus, "resolved");
    print("Ticket " + convert.to_string(crTicketId) + " resolved.");
    return true;
}

fn cmd_close_ticket(ccArgs) {
    let ccUserId = session_require_role("close_ticket");
    if (ccUserId == 0) {
        return true;
    }
    if (list.len(ccArgs) < 2) {
        print("Usage: close-ticket <id>");
        return true;
    }
    let ccTicketId = convert.to_int(list.get(ccArgs, 1));
    let ccTicket = ticket.ticket_find_by_id(ccTicketId);
