fn cmd_add_comment(caArgs) {
    let caUserId = session_require_role("add_comment");
    if (caUserId == 0) {
        return true;
    }
    if (list.len(caArgs) < 3) {
        print("Usage: add-comment <ticket_id> <content>");
        return true;
    }
    let caTicketId = convert.to_int(list.get(caArgs, 1));
    let caContent = list.get(caArgs, 2);
    let caTicket = ticket.ticket_find_by_id(caTicketId);
    if (map.has(caTicket, "id") == false) {
        print("Error: Ticket not found.");
        return true;
    }
    comment.comment_create(caTicketId, caUserId, caContent);
    audit_log.audit_log_add(caTicketId, caUserId, "commented", "", caContent);
    print("Comment added to ticket " + convert.to_string(caTicketId));
    return true;
}

fn cmd_view_ticket(cvArgs) {
    let cvUserId = session_require_role("view_ticket");
    if (cvUserId == 0) {
        return true;
    }
    if (list.len(cvArgs) < 2) {
        print("Usage: view-ticket <id>");
        return true;
    }
    let cvTicketId = convert.to_int(list.get(cvArgs, 1));
    let cvTicket = ticket.ticket_find_by_id(cvTicketId);
    if (map.has(cvTicket, "id") == false) {
        print("Error: Ticket not found.");
        return true;
    }
    print("--- Ticket " + convert.to_string(cvTicketId) + " ---");
    print("Title: " + map.get(cvTicket, "title"));
    print("Status: " + map.get(cvTicket, "status"));
    print("Priority: " + map.get(cvTicket, "priority"));
    print("Category: " + map.get(cvTicket, "category"));
    print("Creator ID: " + convert.to_string(map.get(cvTicket, "creator_id")));
    print("Assignee ID: " + convert.to_string(map.get(cvTicket, "assignee_id")));
    print("Description: " + map.get(cvTicket, "description"));
    print("Created: " + convert.to_string(map.get(cvTicket, "created_at")));
    let cvComments = comment.comment_list_by_ticket(cvTicketId);
    let cvCommentCount = list.len(cvComments);
    if (cvCommentCount > 0) {
        print("--- Comments (" + convert.to_string(cvCommentCount) + ") ---");
        cv_print_comments_rec(cvComments, 0);
    }
    return true;
}

fn cmd_search_tickets(csArgs) {
    let csUserId = session_require_role("search_tickets");
    if (csUserId == 0) {
        return true;
    }
    if (list.len(csArgs) < 2) {
        print("Usage: search-tickets <query>");
        return true;
    }
    let csQuery = list.get(csArgs, 1);
    let csResults = ticket.ticket_search(csQuery);
    let csCount = list.len(csResults);
    print("Found " + convert.to_string(csCount) + " tickets matching '" + csQuery + "'");
    cs_print_results_rec(csResults, 0);
    return true;
}

fn cmd_filter_tickets(cfArgs) {
