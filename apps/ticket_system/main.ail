}

fn cmd_set_role(srArgs) {
    let srUserId = session_require_role("manage_users");
    if (srUserId == 0) {
        return true;
    }
    if (list.len(srArgs) < 3) {
        print("Usage: set-role <username> <role>");
        print("Roles: admin, manager, agent, viewer");
        return true;
    }
    let srUsername = list.get(srArgs, 1);
    let srRole = list.get(srArgs, 2);
    let srTarget = user.user_find_by_username(srUsername);
    if (map.has(srTarget, "id") == false) {
        print("Error: User not found.");
        return true;
    }
    user.user_set_role(map.get(srTarget, "id"), srRole);
    print("Set " + srUsername + " role to " + srRole);
    return true;
}

fn cmd_list_users(clArgs) {
    let clUserId = session_require_role("manage_users");
    if (clUserId == 0) {
        return true;
    }
    let clUsers = user.user_list_all();
    let clCount = list.len(clUsers);
    print("--- Users (" + convert.to_string(clCount) + ") ---");
    cl_print_users_rec(clUsers, 0);
    return true;
}

fn cmd_delete_ticket(cdArgs) {
    let cdUserId = session_require_role("delete_ticket");
    if (cdUserId == 0) {
        return true;
    }
    if (list.len(cdArgs) < 2) {
        print("Usage: delete-ticket <id>");
        return true;
    }
    let cdTicketId = convert.to_int(list.get(cdArgs, 1));
    let cdTicket = ticket.ticket_find_by_id(cdTicketId);
    if (map.has(cdTicket, "id") == false) {
        print("Error: Ticket not found.");
        return true;
    }
    ticket.ticket_delete(cdTicketId);
    audit_log.audit_log_add(cdTicketId, cdUserId, "deleted", map.get(cdTicket, "title"), "");
    print("Ticket " + convert.to_string(cdTicketId) + " deleted.");
    return true;
}

fn cmd_escalate(ceArgs) {
    let ceUserId = session_require_role("view_reports");
    if (ceUserId == 0) {
        return true;
    }
    let ceSlaCount = ticket.ticket_escalate_sla();
    let ceUnassignedCount = ticket.ticket_escalate_unassigned();
    print("Escalation complete:");
    print("  SLA breaches escalated: " + convert.to_string(ceSlaCount));
    print("  Unassigned critical: " + convert.to_string(ceUnassignedCount));
    return true;
}

fn cmd_help(caArgs) {
    print("Available commands:");
    print("  register <username> <email> <password>");
    print("  login <username> <password>");
    print("  logout");
    print("  create-ticket <title> <priority> <category> <description>");
    print("  update-ticket <id> <field> <value>");
    print("  assign-ticket <id> <username>");
    print("  resolve-ticket <id>");
    print("  close-ticket <id>");
    print("  reopen-ticket <id>");
    print("  add-comment <ticket_id> <content>");
    print("  view-ticket <id>");
    print("  search-tickets <query>");
    print("  filter-tickets <field> <value>");
    print("  my-tickets");
    print("  report-status");
    print("  report-priority");
    print("  report-agent");
    print("  report-daily");
    print("  export-csv <filename>");
    print("  import-csv <filename>");
    print("  list-users");
    print("  set-role <username> <role>");
    print("  delete-ticket <id>");
    print("  escalate");
    print("  help");
    return true;
}

fn dispatch_command(dcCmd, dcArgs) {
    if (dcCmd == "register") {
        return cmd_register(dcArgs);
    }
    if (dcCmd == "login") {
        return cmd_login(dcArgs);
    }
    if (dcCmd == "logout") {
        return cmd_logout(dcArgs);
    }
    if (dcCmd == "create-ticket") {
        return cmd_create_ticket(dcArgs);
    }
    if (dcCmd == "update-ticket") {
        return cmd_update_ticket(dcArgs);
    }
    if (dcCmd == "assign-ticket") {
        return cmd_assign_ticket(dcArgs);
    }
    if (dcCmd == "resolve-ticket") {
        return cmd_resolve_ticket(dcArgs);
    }
    if (dcCmd == "close-ticket") {
        return cmd_close_ticket(dcArgs);
    }
    if (dcCmd == "reopen-ticket") {
        return cmd_reopen_ticket(dcArgs);
    }
    if (dcCmd == "add-comment") {
        return cmd_add_comment(dcArgs);
    }
    if (dcCmd == "view-ticket") {
        return cmd_view_ticket(dcArgs);
    }
    if (dcCmd == "search-tickets") {
        return cmd_search_tickets(dcArgs);
    }
    if (dcCmd == "filter-tickets") {
        return cmd_filter_tickets(dcArgs);
    }
    if (dcCmd == "my-tickets") {
        return cmd_my_tickets(dcArgs);
    }
    if (dcCmd == "report-status") {
        return cmd_report_status(dcArgs);
    }
    if (dcCmd == "report-priority") {
        return cmd_report_priority(dcArgs);
    }
    if (dcCmd == "report-agent") {
        return cmd_report_agent(dcArgs);
    }
    if (dcCmd == "report-daily") {
        return cmd_report_daily(dcArgs);
    }
    if (dcCmd == "export-csv") {
        return cmd_export_csv(dcArgs);
    }
    if (dcCmd == "import-csv") {
        return cmd_import_csv(dcArgs);
    }
    if (dcCmd == "list-users") {
        return cmd_list_users(dcArgs);
    }
    if (dcCmd == "set-role") {
        return cmd_set_role(dcArgs);
    }
    if (dcCmd == "delete-ticket") {
        return cmd_delete_ticket(dcArgs);
    }
    if (dcCmd == "escalate") {
        return cmd_escalate(dcArgs);
    }
    if (dcCmd == "help") {
        return cmd_help(dcArgs);
    }
    print("Unknown command: " + dcCmd + ". Type 'help' for available commands.");
    return true;
}

fn main() {
    let args = environment.args();
    if (list.len(args) == 0) {
        print("Ticket Management System v1.0");
        print("Usage: ail run main.ail <command> [args...]");
        print("Type 'help' for available commands.");
        return true;
    }
    let command = list.get(args, 0);
    return dispatch_command(command, args);
}
