fn cmd_report_agent(crArgs) {
    let crUserId = session_require_role("view_reports");
    if (crUserId == 0) {
        return true;
    }
    let crCounts = ticket.ticket_count_by_agent();
    let crTickets = ticket.ticket_list_all();
    let crTotal = list.len(crTickets);
    print("--- Agent Report ---");
    print("Total tickets: " + convert.to_string(crTotal));
    print("Tickets by assignee ID:");
    cr_print_agent_rec(crTickets, crCounts, 0);
    return true;
}

fn cmd_report_daily(crArgs) {
    let crUserId = session_require_role("view_reports");
    if (crUserId == 0) {
        return true;
    }
    let crTickets = ticket.ticket_list_all();
    let crNow = time.timestamp();
    let crSevenDays = 604800;
    let crResult = cr_count_daily_rec(crTickets, crNow, crSevenDays, 0, 0, 0);
    print("--- Daily Report (last 7 days) ---");
    print("Created: " + convert.to_string(crResult));
    return true;
}

fn cmd_export_csv(ceArgs) {
    let ceUserId = session_require_role("export_csv");
    if (ceUserId == 0) {
        return true;
    }
    if (list.len(ceArgs) < 2) {
        print("Usage: export-csv <filename>");
        return true;
    }
    let ceFilename = list.get(ceArgs, 1);
    let ceSuccess = csv_ops.csv_export_tickets(ceFilename);
    if (ceSuccess == true) {
        print("Exported to " + ceFilename);
    } else {
        print("Error: Export failed.");
    }
    return true;
}

fn cmd_import_csv(ciArgs) {
    let ciUserId = session_require_role("import_csv");
    if (ciUserId == 0) {
        return true;
    }
    if (list.len(ciArgs) < 2) {
        print("Usage: import-csv <filename>");
        return true;
    }
    let ciFilename = list.get(ciArgs, 1);
    let ciImported = csv_ops.csv_import_tickets(ciFilename);
    print("Imported " + convert.to_string(ciImported) + " tickets from " + ciFilename);
