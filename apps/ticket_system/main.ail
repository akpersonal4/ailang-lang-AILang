    if (list.len(cfArgs) < 3) {
        print("Usage: filter-tickets <field> <value>");
        return true;
    }
    let cfField = list.get(cfArgs, 1);
    let cfValue = list.get(cfArgs, 2);
    let cfResults = ticket.ticket_filter(cfField, cfValue);
    let cfCount = list.len(cfResults);
    print("Found " + convert.to_string(cfCount) + " tickets with " + cfField + " = " + cfValue);
