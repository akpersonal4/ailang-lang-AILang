}

fn cmd_reopen_ticket(crArgs) {
    let crUserId = session_require_role("reopen_ticket");
    if (crUserId == 0) {
        return true;
    }
    if (list.len(crArgs) < 2) {
        print("Usage: reopen-ticket <id>");
