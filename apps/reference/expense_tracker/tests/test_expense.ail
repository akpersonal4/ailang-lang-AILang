import list;
import map;
import io;
import convert;

fn create_expense(desc, amount, category) {
    let entry = map.new();
    map.set(entry, "desc", desc);
    map.set(entry, "amount", amount);
    map.set(entry, "category", category);
    return entry
}

fn add_expense(expenses, desc, amount, category) {
    let record = create_expense(desc, amount, category);
    list.append(expenses, record);
    return expenses
}

fn total_by_category_helper(expenses, idx, category) {
    if (idx >= list.len(expenses)) {
        return 0
    }
    let entry = list.get(expenses, idx);
    let cat = map.get(entry, "category");
    let amt = map.get(entry, "amount");
    if (cat == category) {
        return total_by_category_helper(expenses, idx + 1, category) + amt
    } else {
        return total_by_category_helper(expenses, idx + 1, category)
    }
}

fn total_by_category(expenses, category) {
    return total_by_category_helper(expenses, 0, category)
}

fn total_all_helper(expenses, idx) {
    if (idx >= list.len(expenses)) {
        return 0
    }
    let entry = list.get(expenses, idx);
    let amt = map.get(entry, "amount");
    return total_all_helper(expenses, idx + 1) + amt
}

fn total_all(expenses) {
    return total_all_helper(expenses, 0)
}

fn test_create_expense() {
    let item = create_expense("Lunch", 15, "Food");
    let desc_val = map.get(item, "desc");
    let amt_val = map.get(item, "amount");
    let cat_val = map.get(item, "category");
    if (desc_val == "Lunch") {
        if (amt_val == 15) {
            if (cat_val == "Food") {
                io.writeln("PASS: create_expense")
            } else {
                io.writeln("FAIL: create_expense - wrong category")
            }
        } else {
            io.writeln("FAIL: create_expense - wrong amount")
        }
    } else {
        io.writeln("FAIL: create_expense - wrong desc")
    }
}

fn test_add_expense() {
    let expenses = list.new();
    expenses = add_expense(expenses, "Lunch", 15, "Food");
    expenses = add_expense(expenses, "Gas", 40, "Transport");
    if (list.len(expenses) == 2) {
        io.writeln("PASS: add_expense")
    } else {
        io.writeln("FAIL: add_expense - expected 2 items")
    }
}

fn test_total_by_category() {
    let expenses = list.new();
    expenses = add_expense(expenses, "Lunch", 15, "Food");
    expenses = add_expense(expenses, "Gas", 40, "Transport");
    expenses = add_expense(expenses, "Dinner", 25, "Food");
    let food = total_by_category(expenses, "Food");
    if (food == 40) {
        io.writeln("PASS: total_by_category")
    } else {
        io.writeln("FAIL: total_by_category - expected 40")
    }
}

fn test_total_all() {
    let expenses = list.new();
    expenses = add_expense(expenses, "Lunch", 15, "Food");
    expenses = add_expense(expenses, "Gas", 40, "Transport");
    let total = total_all(expenses);
    if (total == 55) {
        io.writeln("PASS: total_all")
    } else {
        io.writeln("FAIL: total_all - expected 55")
    }
}

fn main() {
    test_create_expense();
    test_add_expense();
    test_total_by_category();
    test_total_all()
}
