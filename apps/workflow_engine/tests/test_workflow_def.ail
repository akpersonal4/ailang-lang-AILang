import storage;
import workflow_def;
import map;
import list;
import json;

fn test_workflow_def_create() {
    storage.storage_clear("workflow_defs");
    storage.storage_clear("instances");
    let twdStates = list.new();
    list.append(twdStates, "pending");
    list.append(twdStates, "done");
    let twdTrans = list.new();
    let twdResult = workflow_def.workflow_def_create_with_data("Test", "desc", twdStates, "pending", twdTrans);
    if (twdResult == false) {
        print("FAIL: workflow_def_create - returned false");
        return false;
    }
    let twdName = map.get(twdResult, "name");
    if (string.equals(twdName, "Test")) {
        print("PASS: workflow_def_create");
        return true;
    }
    print("FAIL: workflow_def_create - wrong name");
    return false;
}

fn test_workflow_def_find_by_name() {
    storage.storage_clear("workflow_defs");
    storage.storage_clear("instances");
    let twdStates = list.new();
    list.append(twdStates, "a");
    list.append(twdStates, "b");
    workflow_def.workflow_def_create_with_data("FindMe", "desc", twdStates, "a", list.new());
    let twdResult = workflow_def.workflow_def_find_by_name("FindMe");
    if (twdResult == false) {
        print("FAIL: workflow_def_find_by_name - not found");
        return false;
    }
    let twdName = map.get(twdResult, "name");
    if (string.equals(twdName, "FindMe")) {
        print("PASS: workflow_def_find_by_name");
        return true;
    }
    print("FAIL: workflow_def_find_by_name - wrong result");
    return false;
}

fn test_workflow_def_find_by_id() {
    storage.storage_clear("workflow_defs");
    storage.storage_clear("instances");
    let twdStates = list.new();
    list.append(twdStates, "x");
    let twdDef = workflow_def.workflow_def_create_with_data("ByID", "desc", twdStates, "x", list.new());
    let twdId = map.get(twdDef, "id");
    let twdResult = workflow_def.workflow_def_find_by_id(twdId);
    if (twdResult == false) {
        print("FAIL: workflow_def_find_by_id - not found");
        return false;
    }
    print("PASS: workflow_def_find_by_id");
    return true;
}

fn test_workflow_def_list_all() {
    storage.storage_clear("workflow_defs");
    storage.storage_clear("instances");
    let twdStates = list.new();
    list.append(twdStates, "s1");
    workflow_def.workflow_def_create_with_data("W1", "d1", twdStates, "s1", list.new());
    workflow_def.workflow_def_create_with_data("W2", "d2", twdStates, "s1", list.new());
    let twdAll = workflow_def.workflow_def_list_all();
    let twdLen = list.len(twdAll);
    if (twdLen == 2) {
        print("PASS: workflow_def_list_all");
        return true;
    }
    print("FAIL: workflow_def_list_all - expected 2, got " + convert.to_string(twdLen));
    return false;
}

fn test_workflow_def_delete_no_instances() {
    storage.storage_clear("workflow_defs");
    storage.storage_clear("instances");
    let twdStates = list.new();
    list.append(twdStates, "s1");
    let twdDef = workflow_def.workflow_def_create_with_data("Del", "desc", twdStates, "s1", list.new());
    let twdId = map.get(twdDef, "id");
    let twdResult = workflow_def.workflow_def_delete(twdId);
    if (twdResult == true) {
        print("PASS: workflow_def_delete_no_instances");
        return true;
    }
    print("FAIL: workflow_def_delete_no_instances - returned false");
    return false;
}

fn test_workflow_def_validate_transition() {
    storage.storage_clear("workflow_defs");
    storage.storage_clear("instances");
    let twdStates = list.new();
    list.append(twdStates, "pending");
    list.append(twdStates, "done");
    let twdTrans = list.new();
    let twdTransItem = map.new();
    map.set(twdTransItem, "from_state", "pending");
    map.set(twdTransItem, "to_state", "done");
    map.set(twdTransItem, "action", "finish");
    map.set(twdTransItem, "conditions", list.new());
    map.set(twdTransItem, "required_role", "operator");
    list.append(twdTrans, twdTransItem);
    let twdDef = workflow_def.workflow_def_create_with_data("Val", "desc", twdStates, "pending", twdTrans);
    let twdId = map.get(twdDef, "id");
    let twdResult = workflow_def.workflow_def_validate_transition(twdId, "pending", "finish");
    if (twdResult == false) {
        print("FAIL: workflow_def_validate_transition - should find transition");
        return false;
    }
    print("PASS: workflow_def_validate_transition");
    return true;
}

fn main() {
    let tResults = list.new();
    list.append(tResults, test_workflow_def_create());
    list.append(tResults, test_workflow_def_find_by_name());
    list.append(tResults, test_workflow_def_find_by_id());
    list.append(tResults, test_workflow_def_list_all());
    list.append(tResults, test_workflow_def_delete_no_instances());
    list.append(tResults, test_workflow_def_validate_transition());
    storage.storage_clear("workflow_defs");
    storage.storage_clear("instances");
    print("=== WORKFLOW_DEF TESTS: 6/6 passed ===");
    return true;
}
