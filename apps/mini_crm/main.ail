// Mini CRM Platform - AILang Implementation
// Target: 800-1500 LOC, Production-style structure
// Modules: Customer, Product, Invoice, User, Search, Reporting, Export, Audit

import string;
import list;
import map;
import json;
import file;
import time;
import convert;
import io;
import environment;
import system;

// ============================================================
// Level 0: Global Utilities (no dependencies)
// ============================================================

// Find index by key in list of maps
fn find_index_by_key(items, key_name, key_val, idx) {
    if (idx >= list.len(items)) { return -1 }
    let item = list.get(items, idx);
    if (map.has(item, key_name)) {
        if (string.equals(convert.to_string(map.get(item, key_name)), convert.to_string(key_val))) {
            return idx
        }
    }
    return find_index_by_key(items, key_name, key_val, idx + 1)
}

// Join strings with separator (recursive)
fn join_with_sep(items, sep, idx, acc) {
    if (idx >= list.len(items)) { return acc }
    if (idx > 0) { acc = acc + sep }
    acc = acc + convert.to_string(list.get(items, idx));
    return join_with_sep(items, sep, idx + 1, acc)
}

// String to int safe conversion
fn str_to_int_safe(s) {
    return convert.to_int(s)
}

// ============================================================
// Level 1: Storage Layer (no module dependencies)
// ============================================================

let CUSTOMERS_PATH = "apps/mini_crm/data/customers.json";
let PRODUCTS_PATH = "apps/mini_crm/data/products.json";
let INVOICES_PATH = "apps/mini_crm/data/invoices.json";
let USERS_PATH = "apps/mini_crm/data/users.json";
let AUDIT_PATH = "apps/mini_crm/data/audit.json";

fn load_json_list(filepath) {
    if (!file.exists(filepath)) { return list.new() }
    let content = file.read(filepath);
    if (string.length(content) == 0) { return list.new() }
    return json.parse(content)
}

fn save_json_list(filepath, items) {
    let content = json.stringify(items);
    file.write(filepath, content);
    return 0
}

// ID generation
fn gen_next_id(items, prefix, idx, max_num) {
    if (idx >= list.len(items)) {
        if (max_num == 0) { return string.concat(prefix, "001") }
        if (max_num < 9) { return string.concat(string.concat(prefix, "00"), convert.to_string(max_num + 1)) }
        if (max_num < 99) { return string.concat(string.concat(prefix, "0"), convert.to_string(max_num + 1)) }
        return string.concat(prefix, convert.to_string(max_num + 1))
    }
    let item = list.get(items, idx);
    if (map.has(item, "id")) {
        let id_str = convert.to_string(map.get(item, "id"));
        let id_len = string.length(id_str);
        if (id_len > string.length(prefix)) {
            let num_part = string.substring(id_str, string.length(prefix), id_len);
            if (string.equals(num_part, "0") || str_to_int_safe(num_part) > 0) {
                let num_val = str_to_int_safe(num_part);
                if (num_val > max_num) {
                    return gen_next_id(items, prefix, idx + 1, num_val)
                }
            }
        }
    }
    return gen_next_id(items, prefix, idx + 1, max_num)
}

fn generate_id(prefix, items) {
    return gen_next_id(items, prefix, 0, 0)
}

// ============================================================
// Level 2: Customer Module
// ============================================================

fn make_customer(id, name, email, phone, company, status, notes) {
    let c = map.new();
    map.set(c, "id", id);
    map.set(c, "name", name);
    map.set(c, "email", email);
    map.set(c, "phone", phone);
    map.set(c, "company", company);
    map.set(c, "status", status);
    map.set(c, "notes", notes);
    map.set(c, "created", time.now());
    map.set(c, "loyalty_points", 0);
    return c
}

// Customer search helpers (must be before customer_search_by_name)
fn customer_search_by_name_helper(customers, substr, idx, results) {
    if (idx >= list.len(customers)) { return results }
    let c = list.get(customers, idx);
    if (map.has(c, "name")) {
        let name = map.get(c, "name");
        if (string.contains(string.lowercase(name), string.lowercase(substr))) {
            list.append(results, c)
        }
    }
    return customer_search_by_name_helper(customers, substr, idx + 1, results)
}

fn customer_count_by_status_helper(customers, status_val, idx, count) {
    if (idx >= list.len(customers)) { return count }
    let c = list.get(customers, idx);
    if (map.has(c, "status")) {
        if (string.equals(map.get(c, "status"), status_val)) {
            return customer_count_by_status_helper(customers, status_val, idx + 1, count + 1)
        }
    }
    return customer_count_by_status_helper(customers, status_val, idx + 1, count)
}

fn customer_create(id, name, email, phone, company) {
    let customers = load_json_list(CUSTOMERS_PATH);
    let idx = find_index_by_key(customers, "id", id, 0);
    if (idx >= 0) { return "Error: Customer already exists" }
    let customer = make_customer(id, name, email, phone, company, "ACTIVE", "");
    list.append(customers, customer);
    save_json_list(CUSTOMERS_PATH, customers);
    return string.concat("Customer ", string.concat(id, " created"))
}

fn customer_list_all() {
    return load_json_list(CUSTOMERS_PATH)
}

fn customer_find_by_id(customer_id) {
    let customers = load_json_list(CUSTOMERS_PATH);
    let idx = find_index_by_key(customers, "id", customer_id, 0);
    if (idx < 0) { return json.parse("null") }
    return list.get(customers, idx)
}

fn customer_update(customer_id, name, email, phone, company, status, notes) {
    let customers = load_json_list(CUSTOMERS_PATH);
    let idx = find_index_by_key(customers, "id", customer_id, 0);
    if (idx < 0) { return "Error: Customer not found" }
    let c = list.get(customers, idx);
    if (string.length(name) > 0) { map.set(c, "name", name) }
    if (string.length(email) > 0) { map.set(c, "email", email) }
    if (string.length(phone) > 0) { map.set(c, "phone", phone) }
    if (string.length(company) > 0) { map.set(c, "company", company) }
    if (string.length(status) > 0) { map.set(c, "status", status) }
    if (string.length(notes) > 0) { map.set(c, "notes", notes) }
    save_json_list(CUSTOMERS_PATH, customers);
    return string.concat("Customer ", string.concat(customer_id, " updated"))
}

fn customer_delete(customer_id) {
    let customers = load_json_list(CUSTOMERS_PATH);
    let idx = find_index_by_key(customers, "id", customer_id, 0);
    if (idx < 0) { return "Error: Customer not found" }
    let c = list.get(customers, idx);
    list.remove(customers, c);
    save_json_list(CUSTOMERS_PATH, customers);
    return string.concat("Customer ", string.concat(customer_id, " deleted"))
}

fn customer_search_by_name(name_substr) {
    let customers = load_json_list(CUSTOMERS_PATH);
    let results = list.new();
    return customer_search_by_name_helper(customers, name_substr, 0, results)
}

fn customer_set_status(customer_id, status) {
    let customers = load_json_list(CUSTOMERS_PATH);
    let idx = find_index_by_key(customers, "id", customer_id, 0);
    if (idx < 0) { return "Error: Customer not found" }
    let c = list.get(customers, idx);
    map.set(c, "status", status);
    save_json_list(CUSTOMERS_PATH, customers);
    return string.concat("Customer ", string.concat(customer_id, string.concat(" status set to ", status)))
}

fn customer_add_note(customer_id, note) {
    let customers = load_json_list(CUSTOMERS_PATH);
    let idx = find_index_by_key(customers, "id", customer_id, 0);
    if (idx < 0) { return "Error: Customer not found" }
    let c = list.get(customers, idx);
    let existing_notes = "";
    if (map.has(c, "notes")) { existing_notes = map.get(c, "notes") }
    let updated_notes = "";
    if (string.length(existing_notes) > 0) {
        updated_notes = string.concat(string.concat(existing_notes, "; "), note)
    } else {
        updated_notes = note
    }
    map.set(c, "notes", updated_notes);
    save_json_list(CUSTOMERS_PATH, customers);
    return "Note added"
}

// Loyalty points - earn on purchases
fn customer_add_loyalty_points(customer_id, points) {
    let customers = load_json_list(CUSTOMERS_PATH);
    let idx = find_index_by_key(customers, "id", customer_id, 0);
    if (idx < 0) { return "Error: Customer not found" }
    let c = list.get(customers, idx);
    if (map.has(c, "loyalty_points")) {
        let current = map.get(c, "loyalty_points");
        map.set(c, "loyalty_points", current + points)
    } else {
        map.set(c, "loyalty_points", points)
    }
    save_json_list(CUSTOMERS_PATH, customers);
    return "Loyalty points added"
}

fn customer_get_loyalty_points(customer_id) {
    let c = customer_find_by_id(customer_id);
    let none = json.parse("null");
    if (string.equals(convert.to_string(c), convert.to_string(none))) { return 0 }
    if (map.has(c, "loyalty_points")) { return map.get(c, "loyalty_points") }
    return 0
}

// Customer tags - add/remove tags
fn customer_add_tag(customer_id, tag) {
    let customers = load_json_list(CUSTOMERS_PATH);
    let idx = find_index_by_key(customers, "id", customer_id, 0);
    if (idx < 0) { return "Error: Customer not found" }
    let c = list.get(customers, idx);
    let tags = list.new();
    if (map.has(c, "tags")) { tags = map.get(c, "tags") }
    list.append(tags, tag);
    map.set(c, "tags", tags);
    save_json_list(CUSTOMERS_PATH, customers);
    return "Tag added"
}

// Helper must be defined before customer_remove_tag
fn customer_remove_tag_helper(customers, customer_id, tags, tag, idx, new_tags) {
    if (idx >= list.len(tags)) {
        // Write back
        let cust_idx = find_index_by_key(customers, "id", customer_id, 0);
        let c = list.get(customers, cust_idx);
        map.set(c, "tags", new_tags);
        save_json_list(CUSTOMERS_PATH, customers);
        return "Tag removed"
    }
    let t = list.get(tags, idx);
    if (!string.equals(t, tag)) {
        list.append(new_tags, t)
    }
    return customer_remove_tag_helper(customers, customer_id, tags, tag, idx + 1, new_tags)
}

fn customer_remove_tag(customer_id, tag) {
    let customers = load_json_list(CUSTOMERS_PATH);
    let idx = find_index_by_key(customers, "id", customer_id, 0);
    if (idx < 0) { return "Error: Customer not found" }
    let c = list.get(customers, idx);
    if (!map.has(c, "tags")) {
        save_json_list(CUSTOMERS_PATH, customers);
        return "Tag removed"
    }
    let tags = map.get(c, "tags");
    let new_tags = list.new();
    return customer_remove_tag_helper(customers, customer_id, tags, tag, 0, new_tags)
}

fn customer_tags(customer_id) {
    let c = customer_find_by_id(customer_id);
    let none = json.parse("null");
    if (string.equals(convert.to_string(c), convert.to_string(none))) { return list.new() }
    if (map.has(c, "tags")) { return map.get(c, "tags") }
    return list.new()
}

fn customer_count_by_status(status_val) {
    let customers = load_json_list(CUSTOMERS_PATH);
    return customer_count_by_status_helper(customers, status_val, 0, 0)
}

