# Auto-detect text files
* text=auto

# Python
*.py text diff=python
*.pyi text diff=python

# AILang
*.ail text

# Documentation
*.md text
*.rst text

# Config
*.toml text
*.yml text
*.yaml text
*.json text
*.cfg text
*.ini text

# Binary
*.png binary
*.jpg binary
*.ico binary

# Always use LF line endings for shell scripts and git files
*.sh text eol=lf
.gitattributes text
.gitignore text
