{
  "name": "vscode-ailang",
  "displayName": "AILang",
  "description": "AILang language support — syntax highlighting, diagnostics, formatting, hover, go-to-definition, snippets, build/run",
  "version": "1.1.3",
  "publisher": "ailang",
  "license": "Apache-2.0",
  "keywords": [
    "ailang",
    "ail",
    "programming language",
    "AI",
    "deterministic",
    "compiler",
    "LSP",
    "MCP",
    "business applications"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/akpersonal4/ailang-lang-AILang.git"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ailang",
        "aliases": ["AILang", "ailang", "ail"],
        "extensions": [".ail"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ailang",
        "scopeName": "source.ailang",
        "path": "./syntaxes/ailang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "ailang",
        "path": "./snippets/snippets.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "ailang.build",
        "title": "AILang: Build Current File",
        "category": "AILang"
      },
      {
        "command": "ailang.run",
        "title": "AILang: Run Current File",
        "category": "AILang"
      },
      {
        "command": "ailang.check",
        "title": "AILang: Check Current File",
        "category": "AILang"
      },
      {
        "command": "ailang.version",
        "title": "AILang: Show Version",
        "category": "AILang"
      },
      {
        "command": "ailang.format",
        "title": "AILang: Format Document",
        "category": "AILang"
      },
      {
        "command": "ailang.showOutput",
        "title": "AILang: Show Output Channel",
        "category": "AILang"
      },
      {
        "command": "ailang.mcp.start",
        "title": "AILang MCP: Start Server",
        "category": "AILang MCP"
      },
      {
        "command": "ailang.mcp.stop",
        "title": "AILang MCP: Stop Server",
        "category": "AILang MCP"
      },
      {
        "command": "ailang.mcp.restart",
        "title": "AILang MCP: Restart Server",
        "category": "AILang MCP"
      },
      {
        "command": "ailang.mcp.compile",
        "title": "AILang MCP: Compile Current File",
        "category": "AILang MCP"
      },
      {
        "command": "ailang.mcp.explainDiagnostic",
        "title": "AILang MCP: Explain Diagnostic Under Cursor",
        "category": "AILang MCP"
      },
      {
        "command": "ailang.mcp.insertExample",
        "title": "AILang MCP: Insert Code Example",
        "category": "AILang MCP"
      }
    ],
    "configuration": {
      "title": "AILang",
      "properties": {
        "ailang.compilerPath": {
          "type": "string",
          "default": "ail",
          "description": "Path to the 'ail' CLI executable. Override if 'ail' is not on PATH."
        },
        "ailang.formatOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Format AILang files automatically when saving."
        },
        "ailang.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time error checking while editing."
        },
        "ailang.maxProblems": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of diagnostics to report per file."
        },
        "ailang.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Log LSP communication for debugging."
        },
        "ailang.mcp.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the MCP server when the extension activates."
        },
        "ailang.mcp.command": {
          "type": "string",
          "default": "ail",
          "description": "Command to launch the MCP server."
        },
        "ailang.mcp.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["mcp"],
          "description": "Arguments passed to the MCP server command."
        },
        "ailang.mcp.timeout": {
          "type": "number",
          "default": 30000,
          "description": "Timeout in milliseconds for MCP server initialization and tool calls."
        },
        "ailang.mcp.maxReconnectAttempts": {
          "type": "number",
          "default": 3,
          "description": "Maximum number of reconnect attempts after an unexpected server exit."
        }
      }
    }
  },
  "main": "extension.js",
  "activationEvents": ["onLanguage:ailang"],
  "scripts": {
    "vscode:prepublish": "echo 'No compilation needed for JavaScript extension'"
  },
  "devDependencies": {
    "vscode-languageclient": "^9.0.0",
    "typescript": "^5.0.0"
  }
}
