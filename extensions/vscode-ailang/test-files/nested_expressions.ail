// === AILang nested expressions test file ===

import math;
import convert;

fn main() {
    // Nested arithmetic
    let a = (1 + 2) * 3;
    let b = 10 / (5 - 3);
    let c = (1 + 2) * (3 + 4) - 5;

    // Nested function calls
    let d = math.add(math.add(1, 2), math.add(3, 4));

    // Complex condition
    if (a > 5 && b < 10) {
        print("both true");
    }

    // Chained comparisons
    let in_range = 5 > 0 && 5 < 10;

    print(a, b, c, d, in_range);
    return 0
}
