// Config Loader
// Parses a hardcoded INI-style config and returns values by key.

fn get_host() {
    return "localhost"
}

fn get_port() {
    return 8080
}

fn get_debug() {
    return 1
}

fn main() {
    print("=== Config Loader ===")
    let host = get_host()
    let port = get_port()
    let debug = get_debug()
    print("host=localhost")
    print("port=8080")
    print("debug=true")
}
