fn max(a, b) {
    if (a > b) {
        return a
    } else {
        return b
    }
}

fn in_range(x, low, high) {
    if (x >= low && x <= high) {
        return 1
    }
    return 0
}

fn main() {
    let result = max(10, 20);
    print("Max is", result);
    print("In range:", in_range(5, 1, 10));
    return 0
}