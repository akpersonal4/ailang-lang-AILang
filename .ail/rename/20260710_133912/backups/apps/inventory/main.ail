fn main_demo_create_products() {
    let cat1 = category.category_create("Electronics", "Electronic devices and accessories", "");
    let cat2 = category.category_create("Office Supplies", "Paper, pens, and office equipment", "");
    let cat1Id = helpers.helpers_get_map_value_safe(cat1, "id", "");
    let cat2Id = helpers.helpers_get_map_value_safe(cat2, "id", "");
    let prod1 = product.product_create("Laptop", "High-performance laptop", "LAP-001", cat1Id, 1200, 900, "pcs");
    let prod2 = product.product_create("Mouse", "Wireless mouse", "MOU-001", cat1Id, 25, 15, "pcs");
    let prod3 = product.product_create("Notebook", "A5 ruled notebook", "NTB-001", cat2Id, 5, 3, "pcs");
    let prod4 = product.product_create("Desk Lamp", "LED desk lamp", "LMP-001", cat2Id, 45, 30, "pcs");
    print("Created 2 categories and 4 products");
    return true;
}

fn main_demo_create_customers() {
    let cust1 = customer.customer_create("Alice Corp", "alice@example.com", "555-0101");
    let cust2 = customer.customer_create("Bob Industries", "bob@example.com", "555-0102");
    let cust3 = customer.customer_create("Charlie Ltd", "charlie@example.com", "555-0103");
    print("Created 3 customers");
    return true;
}

fn main_demo_create_vendors() {
    let ven1 = vendor.vendor_create("TechSupply Inc", "info@techsupply.com", "555-0201", "John Vendor");
    let ven2 = vendor.vendor_create("OfficeMart", "sales@officemart.com", "555-0202", "Jane Vendor");
    print("Created 2 vendors");
    return true;
}

fn main_demo_stock_and_orders() {
    let allProducts = product.product_list();
    let prodCount = list.len(allProducts);
    if (prodCount == 0) {
        print("No products found. Run init first.");
        return false;
    }
    let firstProd = list.get(allProducts, 0);
    let firstProdId = helpers.helpers_get_map_value_safe(firstProd, "id", "");
    stock_movement.movement_create(firstProdId, "inbound", 50, "manual", "", "Initial stock");
    print("Created inbound movement for first product");
    let allCustomers = customer.customer_list();
    if (list.len(allCustomers) > 0) {
        let firstCust = list.get(allCustomers, 0);
        let firstCustId = helpers.helpers_get_map_value_safe(firstCust, "id", "");
        let newOrder = order_sales_order.sales_create(firstCustId, "First test order");
        let orderId = helpers.helpers_get_map_value_safe(newOrder, "id", "");
        order_sales_order.sales_add_item(orderId, firstProdId, 2, helpers.helpers_get_map_value_safe(firstProd, "unit_price", 0));
        print("Created sales order with 1 item");
    }
    let allVendors = vendor.vendor_list();
    if (list.len(allVendors) > 0) {
        let firstVen = list.get(allVendors, 0);
        let firstVenId = helpers.helpers_get_map_value_safe(firstVen, "id", "");
        let newPO = order_purchase_order.purchase_create(firstVenId, "First purchase order");
        let poId = helpers.helpers_get_map_value_safe(newPO, "id", "");
        order_purchase_order.purchase_add_item(poId, firstProdId, 10, 850);
        print("Created purchase order with 1 item");
    }
    return true;
}

fn main_report() {
    let allProducts = product.product_list();
    let prodCount = list.len(allProducts);
    let allCustomers = customer.customer_list();
    let custCount = list.len(allCustomers);
    let allVendors = vendor.vendor_list();
    let venCount = list.len(allVendors);
    let allMovements = stock_movement.movement_list();
    let movCount = list.len(allMovements);
    let allSales = order_sales_order.sales_list();
    let salesCount = list.len(allSales);
    let allPurchases = order_purchase_order.purchase_list();
    let purchaseCount = list.len(allPurchases);
    print("=== INVENTORY REPORT ===");
    print("Products: " + convert.to_string(prodCount));
    print("Categories: " + convert.to_string(list.len(category.category_list())));
    print("Customers: " + convert.to_string(custCount));
    print("Vendors: " + convert.to_string(venCount));
    print("Stock Movements: " + convert.to_string(movCount));
    print("Sales Orders: " + convert.to_string(salesCount));
    print("Purchase Orders: " + convert.to_string(purchaseCount));
    print("=== END REPORT ===");
    return true;
}

