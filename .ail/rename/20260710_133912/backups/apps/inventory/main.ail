    return true;
}

fn main_export_json() {
    let jsonProducts = export_json_export.json_export_products();
    print("=== PRODUCTS JSON ===");
    print(jsonProducts);
    print("=== END ===");
    return true;
}

fn main_help() {
    print("Usage: ail run main.ail <command>");
    print("");
    print("Commands:");
    print("  init       - Initialize demo data (products, customers, vendors)");
    print("  stock      - Create demo stock movements and orders");
    print("  report     - Show inventory summary report");
    print("  csv        - Export products as CSV");
    print("  json       - Export products as JSON");
    print("  search <q> - Search across all entities");
    print("  seed       - Seed demo data for all modules");
    print("  reserve    - Create demo stock reservation");
    print("  adjust     - Create demo stock adjustment");
    print("  warehouse  - List warehouses");
    print("  dashboard  - Show dashboard summary");
    print("  permission - Demo permission operations");
    print("  batch      - Demo batch operations");
    print("  workflow   - Demo workflow operations");
    print("  audit_full - Show full audit report");
    print("  help       - Show this help");
    return true;
}

fn main_seed() {
    data_seed.seed_all();
    return 0;
}

fn main_reserve() {
    let mrAllProducts = product.product_list();
    let mrProdCount = list.len(mrAllProducts);
    if (mrProdCount == 0) {
        print("No products found. Run init first.");
        return false;
    }
    let mrFirst = list.get(mrAllProducts, 0);
    let mrFirstId = helpers.helpers_get_map_value_safe(mrFirst, "id", "");
    let mrReservation = stock_reservation.reservation_create("DEMO-ORDER", mrFirstId, 5);
    if (mrReservation == false) {
        print("Failed to create reservation (insufficient stock)");
    } else {
        print("Created demo reservation");
    }
    return true;
}

fn main_adjust() {
    let maAllProducts = product.product_list();
    let maProdCount = list.len(maAllProducts);
    if (maProdCount == 0) {
        print("No products found. Run init first.");
        return false;
    }
    let maFirst = list.get(maAllProducts, 0);
    let maFirstId = helpers.helpers_get_map_value_safe(maFirst, "id", "");
    stock_adjustment.adjustment_create(maFirstId, 100, 95, "Cycle count adjustment", "Demo User");
    print("Created demo stock adjustment");
    return true;
}

fn main_warehouse() {
    let mwAll = warehouse.warehouse_list();
    let mwCount = list.len(mwAll);
    print("Total warehouses: " + convert.to_string(mwCount));
    return true;
}

fn main_dashboard() {
    let mdSummary = dashboard.dashboard_summary();
    let mdProducts = helpers.helpers_get_map_value_safe(mdSummary, "total_products", 0);
    let mdCat = helpers.helpers_get_map_value_safe(mdSummary, "total_categories", 0);
    let mdCust = helpers.helpers_get_map_value_safe(mdSummary, "total_customers", 0);
    let mdVend = helpers.helpers_get_map_value_safe(mdSummary, "total_vendors", 0);
    let mdMov = helpers.helpers_get_map_value_safe(mdSummary, "total_movements", 0);
    let mdSales = helpers.helpers_get_map_value_safe(mdSummary, "total_sales_orders", 0);
    let mdPurch = helpers.helpers_get_map_value_safe(mdSummary, "total_purchase_orders", 0);
    let mdWH = helpers.helpers_get_map_value_safe(mdSummary, "total_warehouses", 0);
    print("=== DASHBOARD SUMMARY ===");
    print("Products: " + convert.to_string(mdProducts));
    print("Categories: " + convert.to_string(mdCat));
    print("Customers: " + convert.to_string(mdCust));
    print("Vendors: " + convert.to_string(mdVend));
    print("Stock Movements: " + convert.to_string(mdMov));
    print("Sales Orders: " + convert.to_string(mdSales));
    print("Purchase Orders: " + convert.to_string(mdPurch));
    print("Warehouses: " + convert.to_string(mdWH));
    print("=== END ===");
    return true;
}

fn main_permission() {
    let mpDefined = permission.permission_define("admin", "products", list.new());
    permission.permission_add_action("admin", "products", "create");
    permission.permission_add_action("admin", "products", "read");
    permission.permission_add_action("admin", "products", "update");
    permission.permission_add_action("admin", "products", "delete");
    let mpCheck = permission.permission_check("admin", "products", "create");
    if (mpCheck) {
        print("Permission check passed: admin can create products");
    } else {
        print("Permission check failed");
    }
    return true;
}

fn main_batch() {
    let mbAll = batch.batch_list();
    let mbCount = list.len(mbAll);
    print("Total batches: " + convert.to_string(mbCount));
    return true;
}

fn main_workflow() {
    let mwAll = workflow.workflow_pending_approvals();
    let mwCount = list.len(mwAll);
    print("Pending workflow approvals: " + convert.to_string(mwCount));
    return true;
}

fn main_audit_full() {
    let mafReport = audit_integration.audit_integration_full_report();
    print(mafReport);
    return true;
}

fn main() {
    let mainArgs = environment.args();
    let mainArgCount = list.len(mainArgs);
    if (mainArgCount < 2) {
        return main_help();
    }
    let mainCommand = list.get(mainArgs, 1);
    if (mainCommand == "init") {
        main_demo_create_products();
        main_demo_create_customers();
        main_demo_create_vendors();
        return 0;
    }
    if (mainCommand == "stock") {
        main_demo_stock_and_orders();
        return 0;
    }
    if (mainCommand == "report") {
        main_report();
        return 0;
    }
    if (mainCommand == "csv") {
        main_export_csv();
        return 0;
    }
    if (mainCommand == "json") {
        main_export_json();
        return 0;
    }
    if (mainCommand == "seed") {
        main_seed();
        return 0;
    }
    if (mainCommand == "reserve") {
        main_reserve();
        return 0;
    }
    if (mainCommand == "adjust") {
        main_adjust();
        return 0;
    }
    if (mainCommand == "warehouse") {
        main_warehouse();
        return 0;
    }
    if (mainCommand == "dashboard") {
        main_dashboard();
        return 0;
    }
    if (mainCommand == "permission") {
        main_permission();
        return 0;
    }
    if (mainCommand == "batch") {
        main_batch();
        return 0;
    }
    if (mainCommand == "workflow") {
        main_workflow();
        return 0;
    }
    if (mainCommand == "audit_full") {
        main_audit_full();
        return 0;
    }
    if (mainCommand == "help") {
        main_help();
        return 0;
    }
    print("Unknown command: " + mainCommand);
    main_help();
    return 1;
}
